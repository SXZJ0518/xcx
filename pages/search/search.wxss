/* pages/search/search.wxss */
.search-container {
  padding: 0;
  background-color: #f8f8f8;
}

/* 搜索框 */
.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-box {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  padding: 0 20rpx;
  height: 70rpx;
  align-items: center;
  margin-right: 20rpx;
}

.search-icon {
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
}

.clear-icon {
  padding: 0 10rpx;
}

.search-btn {
  width: 100rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  color: #333;
  font-size: 30rpx;
}

/* 历史搜索 */
.history-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
}

.clear-btn image {
  width: 100%;
  height: 100%;
}

/* 热门搜索 */
.hot-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.tag-item {
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  margin: 10rpx;
  position: relative;
}

.tag-item.hot {
  color: #ff4d4f;
  padding-right: 30rpx;
}

.hot-flag {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 16rpx;
  padding: 2rpx 6rpx;
  border-radius: 10rpx;
  transform: scale(0.8);
}

/* 搜索结果 */
.search-results {
  padding: 0 20rpx;
}

.result-count {
  margin: 20rpx 0;
  font-size: 28rpx;
  color: #999;
}

.product-list {
  margin-bottom: 30rpx;
}

.product-item {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  display: flex;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.product-brief {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.product-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  color: #ff4d4f;
  font-weight: bold;
  font-size: 32rpx;
}

.sold-count {
  font-size: 24rpx;
  color: #999;
}

/* 加载状态 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #7BAE29;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 10rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-more text, .no-more text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
}

/* 空结果 */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}