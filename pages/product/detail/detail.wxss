/* 商品详情页 - 东方禅意 */

.page {
  min-height: 100vh;
  background: #f5f0e8;
}

/* Hero 图片 */
.product-hero {
  position: relative;
  height: 500rpx;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(to top, rgba(245, 240, 232, 1), transparent);
}

/* 商品信息 */
.product-info {
  padding: 40rpx 30rpx;
  background: #fff;
}

.product-name {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #2d2520;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.product-brief {
  display: block;
  font-size: 26rpx;
  color: #8b7355;
  margin-bottom: 30rpx;
}

.product-meta {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-top: 1rpx solid #e8e0d5;
  border-bottom: 1rpx solid #e8e0d5;
  margin-bottom: 30rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.meta-label {
  font-size: 22rpx;
  color: #a09080;
  margin-bottom: 8rpx;
}

.meta-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #2d2520;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.price-current {
  font-size: 48rpx;
  font-weight: 600;
  color: #b8860b;
  margin-right: 16rpx;
}

.price-original {
  font-size: 28rpx;
  color: #a09080;
  text-decoration: line-through;
  margin-right: 24rpx;
}

.price-weight {
  font-size: 24rpx;
  color: #8b7355;
  padding: 6rpx 16rpx;
  background: #f5f0e8;
  border-radius: 20rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  color: #c9a86c;
  padding: 8rpx 20rpx;
  background: rgba(201, 168, 108, 0.1);
  border-radius: 20rpx;
  margin-right: 16rpx;
  margin-bottom: 12rpx;
}

/* 通用 Section */
.section {
  padding: 50rpx 30rpx;
  background: #fff;
  margin-top: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.section-title text:nth-child(2) {
  font-size: 28rpx;
  font-weight: 500;
  color: #2d2520;
  letter-spacing: 4rpx;
  margin: 0 20rpx;
}

.title-line {
  width: 60rpx;
  height: 1rpx;
  background: #d4c4b0;
}

.story-content {
  text-align: justify;
}

.story-content text {
  font-size: 26rpx;
  color: #5a5045;
  line-height: 2;
}

/* 香型特征 */
.aroma-section {
  background: linear-gradient(135deg, #f8f3eb, #f0ebe3);
}

.aroma-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 37, 32, 0.06);
}

.aroma-item {
  margin-bottom: 24rpx;
}

.aroma-item:last-child {
  margin-bottom: 0;
}

.aroma-label {
  display: block;
  font-size: 22rpx;
  color: #c9a86c;
  font-weight: 500;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.aroma-value {
  display: block;
  font-size: 26rpx;
  color: #5a5045;
  line-height: 1.8;
}

/* 冲泡建议 */
.brew-section {
  background: linear-gradient(135deg, #2d2520, #3d3530);
}

.brew-section .section-title text:nth-child(2) {
  color: #c9a86c;
}

.brew-section .title-line {
  background: rgba(201, 168, 108, 0.3);
}

.brew-grid {
  display: flex;
  justify-content: space-around;
}

.brew-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brew-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.brew-label {
  font-size: 22rpx;
  color: #a09080;
  margin-bottom: 8rpx;
}

.brew-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #c9a86c;
}

/* 联系客服 */
.contact-section {
  padding: 40rpx 30rpx;
}

.contact-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(45, 37, 32, 0.08);
}

.contact-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #2d2520;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.contact-desc {
  display: block;
  font-size: 24rpx;
  color: #8b7355;
  margin-bottom: 40rpx;
}

.contact-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #c9a86c, #b8965c);
  border-radius: 50rpx;
  border: none;
}

.contact-btn::after {
  border: none;
}

.contact-btn text {
  font-size: 28rpx;
  color: #fff;
  letter-spacing: 2rpx;
}

.footer-space {
  height: 60rpx;
}
