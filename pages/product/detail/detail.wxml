<view class="page">
  <!-- 商品图片 -->
  <view class="product-hero">
    <image src="{{product.imageUrl || '/images/tea-placeholder.jpg'}}" mode="aspectFill" class="hero-image"></image>
    <view class="hero-overlay"></view>
  </view>

  <!-- 商品信息 -->
  <view class="product-info" wx:if="{{product.name}}">
    <text class="product-name">{{product.name}}</text>
    <text class="product-brief" wx:if="{{product.brief}}">{{product.brief}}</text>
    


    <view class="product-price-row">
      <text class="price-current">¥{{product.price}}</text>
      <text class="price-original" wx:if="{{product.originalPrice}}">¥{{product.originalPrice}}</text>
      <text class="price-weight" wx:if="{{product.weight}}">{{product.weight}}</text>
    </view>

    <view class="product-tags" wx:if="{{product.tags && product.tags.length > 0}}">
      <text class="tag" wx:for="{{product.tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <!-- 商品信息为空时的提示 -->
  <view class="product-info" wx:else>
    <text class="product-name">商品加载中...</text>
  </view>

  <!-- 产品故事 -->
  <view class="section" wx:if="{{product.description}}">
    <view class="section-title">
      <text class="title-line"></text>
      <text>产品故事</text>
      <text class="title-line"></text>
    </view>
    <view class="story-content">
      <text>{{product.description}}</text>
    </view>
  </view>

  <!-- 香型特征 -->
  <view class="section aroma-section" wx:if="{{product.aromaFeature}}">
    <view class="section-title">
      <text class="title-line"></text>
      <text>香型特征 · {{product.categoryName}}</text>
      <text class="title-line"></text>
    </view>
    <view class="aroma-card">
      <view class="aroma-item">
        <text class="aroma-label">香气特征</text>
        <text class="aroma-value">{{product.aromaFeature}}</text>
      </view>
      <view class="aroma-item" wx:if="{{product.representative}}">
        <text class="aroma-label">代表品种</text>
        <text class="aroma-value">{{product.representative}}</text>
      </view>
      <view class="aroma-item" wx:if="{{product.qualityFeature}}">
        <text class="aroma-label">品质特点</text>
        <text class="aroma-value">{{product.qualityFeature}}</text>
      </view>
    </view>
  </view>

  <!-- 冲泡建议 -->
  <view class="section brew-section" wx:if="{{product.brewTemp || product.brewTime || product.brewCount}}">
    <view class="section-title">
      <text class="title-line"></text>
      <text>冲泡建议</text>
      <text class="title-line"></text>
    </view>
    <view class="brew-grid">
      <view class="brew-item">
        <text class="brew-icon">🌡️</text>
        <text class="brew-label">水温</text>
        <text class="brew-value">{{product.brewTemp}}</text>
      </view>
      <view class="brew-item">
        <text class="brew-icon">⏱️</text>
        <text class="brew-label">时间</text>
        <text class="brew-value">{{product.brewTime}}</text>
      </view>
      <view class="brew-item">
        <text class="brew-icon">🔄</text>
        <text class="brew-label">次数</text>
        <text class="brew-value">{{product.brewCount}}</text>
      </view>
    </view>
  </view>

  <!-- 联系客服 -->
  <view class="contact-section">
    <view class="contact-card">
      <text class="contact-title">{{siteConfig.productContactTitle || '品茶咨询'}}</text>
      <text class="contact-desc">{{siteConfig.productContactDesc || '添加微信，了解更多详情'}}</text>
      <button class="contact-btn" bindtap="copyWechat">
        <text>{{siteConfig.productContactBtnText || '复制微信号'}}</text>
      </button>
    </view>
  </view>

  <!-- 底部留白（给固定栏让位） -->
  <view class="footer-space"></view>

  <!-- ========== 底部固定操作栏 ========== -->
  <view class="bottom-bar">
    <view class="bb-favorite {{isFavorited ? 'favorited' : ''}}" bindtap="toggleFavorite">
      <text class="bb-fav-icon">{{isFavorited ? '❤️' : '🤍'}}</text>
      <text class="bb-fav-text">{{isFavorited ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="bb-order" bindtap="showOrder">
      <text class="bb-order-text">立即下单</text>
    </view>
  </view>
</view>
