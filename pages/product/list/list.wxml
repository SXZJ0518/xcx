<!--
  茶品列表页 - 左侧垂直导航 + 右侧商品列表
  设计：侧边栏导航，当前分类高亮
-->
<view class="page">

  <!-- 顶部搜索栏 -->
  <view class="search-bar-wrap" bindtap="onSearchTap">
    <view class="search-bar-inner">
      <view class="search-icon">
        <view class="icon-search-dot"></view>
        <view class="icon-search-line"></view>
      </view>
      <text class="search-placeholder">搜索茶品、香型...</text>
    </view>
  </view>

  <!-- 主体：左侧导航 + 右侧内容 -->
  <view class="main-body">

    <!-- 左侧分类导航 -->
    <scroll-view class="side-nav" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        class="nav-item {{currentCategory === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="switchCategory"
        data-cat="{{item.id}}"
      >
        <view class="nav-line" wx:if="{{currentCategory === item.id}}"></view>
        <text class="nav-text">{{item.name}}</text>
        <view class="nav-badge" wx:if="{{item.id === 'cat_special'}}">省</view>
      </view>
    </scroll-view>

    <!-- 右侧商品列表 -->
    <scroll-view
      class="product-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      bindscrolltolower="onReachBottom"
      refresher-enabled="{{true}}"
      bindrefresherrefresh="onPullDownRefresh"
      refresher-triggered="{{isRefreshing}}"
    >
      <view class="product-list" wx:if="{{products.length > 0}}">
        <view
          class="p-card"
          wx:for="{{products}}"
          wx:key="id"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          <!-- 图片区 -->
          <view class="p-image">
            <image src="{{item.imageUrl || item.cover}}" mode="aspectFill" lazy-load />
            <view class="p-overlay"></view>
            <!-- 角标 -->
            <view class="p-tag-special" wx:if="{{currentCategory === 'cat_special'}}">特惠</view>
            <view class="p-tag-new" wx:elif="{{item.isNew}}">新</view>
          </view>

          <!-- 信息区 -->
          <view class="p-info">
            <text class="p-name">{{item.name}}</text>
            <text class="p-brief" wx:if="{{item.brief}}">{{item.brief}}</text>

            <!-- 香型标签 -->
            <view class="p-aroma-row" wx:if="{{item.aromaName}}">
              <text class="p-aroma">{{item.aromaName}}</text>
            </view>

            <!-- 价格 -->
            <view class="p-price-row">
              <view class="p-price-box">
                <text class="p-symbol">¥</text>
                <text class="p-price">{{item.price}}</text>
                <text class="p-original" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
              </view>
              <text class="p-weight">{{item.weight}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!isLoading && products.length === 0}}">
        <view class="empty-icon">
          <view class="empty-leaf"></view>
        </view>
        <text class="empty-title">暂无茶品</text>
        <text class="empty-hint">该分类下暂时没有商品</text>
      </view>

      <!-- 加载中 -->
      <view class="loading-more" wx:if="{{isLoading}}">
        <view class="loading-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>

      <!-- 没有更多 -->
      <view class="no-more" wx:if="{{!isLoading && products.length > 0 && !hasMore}}">
        <text>已展示全部茶品</text>
      </view>

      <!-- 底部留白 -->
      <view class="list-footer"></view>
    </scroll-view>

  </view>

</view>
