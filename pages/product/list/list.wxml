<!--
  茶品列表页 - 整页连续滚动，左侧导航自动高亮
  设计：下滑自动切换分类，点击导航跳转到对应分类
-->
<view class="page">

  <!-- 顶部搜索栏 -->
  <view class="search-bar-wrap" bindtap="onSearchTap">
    <view class="search-bar-inner">
      <view class="search-icon">
        <view class="icon-search-dot"></view>
        <view class="icon-search-line"></view>
      </view>
      <text class="search-placeholder">搜索茶品、香型...</text>
    </view>
  </view>

  <!-- 主体：左侧固定导航 + 右侧整页滚动 -->
  <view class="main-body">

    <!-- 左侧分类导航（固定） -->
    <view class="side-nav">
      <view
        class="nav-item {{currentCategory === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="switchCategory"
        data-cat="{{item.id}}"
        data-index="{{index}}"
        id="nav-{{item.id}}"
      >
        <view class="nav-line" wx:if="{{currentCategory === item.id}}"></view>
        <text class="nav-text">{{item.name}}</text>
      </view>
    </view>

    <!-- 右侧：所有分类的商品连续排列 -->
    <scroll-view
      class="product-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{scrollIntoView}}"
      scroll-with-animation
      bindscrolltolower="loadMore"
      refresher-enabled="{{true}}"
      bindrefresherrefresh="onPullDownRefresh"
      refresher-triggered="{{isRefreshing}}"
    >
      <view class="product-scroll-inner">

        <!-- 每个分类一个区块 -->
        <view
          class="category-section"
          wx:for="{{categories}}"
          wx:key="id"
          id="section-{{item.id}}"
        >
          <!-- 分类标题 -->
          <view class="section-header">
            <view class="section-mark"></view>
            <text class="section-title">{{item.name}}</text>
            <text class="section-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
          </view>

          <!-- 该分类下的商品 -->
          <view class="section-products" wx:if="{{groupedProducts[item.id] && groupedProducts[item.id].length > 0}}">
            <view
              class="p-card"
              wx:for="{{groupedProducts[item.id]}}"
              wx:for-item="product"
              wx:key="id"
              bindtap="goToDetail"
              data-id="{{product.id}}"
            >
              <view class="p-image">
                <image src="{{product.imageUrl || product.cover}}" mode="aspectFill" lazy-load />
                <view class="p-overlay"></view>
                <!-- 动态图片标签 -->
                <view
                  class="p-tag-dynamic"
                  wx:if="{{product.imageTag}}"
                  style="background: {{product.imageTag.bg}}; color: {{product.imageTag.textColor}};"
                >{{product.imageTag.text}}</view>
              </view>
              <view class="p-info">
                <text class="p-name">{{product.name}}</text>
                <text class="p-brief" wx:if="{{product.brief}}">{{product.brief}}</text>
                <view class="p-aroma-row" wx:if="{{product.aromaName}}">
                  <text class="p-aroma">{{product.aromaName}}</text>
                </view>
                <view class="p-price-row">
                  <view class="p-price-box">
                    <text class="p-symbol">¥</text>
                    <text class="p-price">{{product.price}}</text>
                    <text class="p-original" wx:if="{{product.originalPrice}}">¥{{product.originalPrice}}</text>
                  </view>
                  <text class="p-weight">{{product.weight}}</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 该分类暂无商品 -->
          <view class="section-empty" wx:else>
            <text class="section-empty-text">暂无商品</text>
          </view>

          <!-- 分类之间的间距 -->
          <view class="section-gap"></view>
        </view>

        <!-- 加载中 -->
        <view class="loading-more" wx:if="{{isLoading}}">
          <view class="loading-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>

        <!-- 底部留白 -->
        <view class="list-footer"></view>
      </view>
    </scroll-view>

  </view>

</view>
