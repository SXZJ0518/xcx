<view class="page">

  <!-- ========== 1. 顶部搜索栏（装饰性） ========== -->
  <view class="search-bar-wrap" bindtap="onSearchTap">
    <view class="search-bar-inner">
      <view class="search-icon">
        <view class="icon-search-dot"></view>
        <view class="icon-search-line"></view>
      </view>
      <text class="search-placeholder">搜索茶品、香型...</text>
    </view>
  </view>

  <!-- ========== 2. 分类标签栏（第一行） ========== -->
  <view class="category-tabs">
    <view
      class="category-tab {{currentCategory === 'cat_normal' ? 'active' : ''}}"
      bindtap="switchCategory"
      data-cat="cat_normal"
    >单枞茶</view>
    <view
      class="category-tab {{currentCategory === 'cat_special' ? 'active' : ''}}"
      bindtap="switchCategory"
      data-cat="cat_special"
    >特惠茶</view>
    <view
      class="category-tab {{currentCategory === 'cat_farm' ? 'active' : ''}}"
      bindtap="switchCategory"
      data-cat="cat_farm"
    >农产品</view>
  </view>

  <!-- ========== 3. 筛选栏（第二行，仅单枞茶时显示） ========== -->
  <view class="filter-bar" wx:if="{{currentCategory === 'cat_normal'}}">
    <!-- 包装筛选 -->
    <view class="filter-row">
      <text class="filter-label">包装</text>
      <view class="filter-options">
        <view
          class="filter-option {{currentPackType === 'all' ? 'active' : ''}}"
          bindtap="switchPackType"
          data-pack="all"
        >全部</view>
        <view
          class="filter-option {{currentPackType === 'bag' ? 'active' : ''}}"
          bindtap="switchPackType"
          data-pack="bag"
        >袋装</view>
        <view
          class="filter-option {{currentPackType === 'can' ? 'active' : ''}}"
          bindtap="switchPackType"
          data-pack="can"
        >铁罐</view>
        <view
          class="filter-option {{currentPackType === 'gift' ? 'active' : ''}}"
          bindtap="switchPackType"
          data-pack="gift"
        >礼盒</view>
      </view>
    </view>
    <!-- 季节筛选 -->
    <view class="filter-row">
      <text class="filter-label">季节</text>
      <view class="filter-options">
        <view
          class="filter-option {{currentSeason === 'all' ? 'active' : ''}}"
          bindtap="switchSeason"
          data-season="all"
        >全部</view>
        <view
          class="filter-option {{currentSeason === 'spring' ? 'active' : ''}}"
          bindtap="switchSeason"
          data-season="spring"
        >春茶</view>
        <view
          class="filter-option {{currentSeason === 'second_spring' ? 'active' : ''}}"
          bindtap="switchSeason"
          data-season="second_spring"
        >二春</view>
      </view>
    </view>
  </view>

  <!-- ========== 4. 商品网格（2列） ========== -->
  <view class="product-grid" wx:if="{{products.length > 0}}">
    <view
      class="product-card"
      wx:for="{{products}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <!-- 特惠角标 -->
      <view class="special-badge" wx:if="{{currentCategory === 'cat_special'}}">特惠</view>
      <view class="new-badge" wx:elif="{{item.isNew}}">新品</view>

      <view class="product-image">
        <image src="{{item.imageUrl || '/images/banner/banner1.jpg'}}" mode="aspectFill" lazy-load="true"></image>
      </view>

      <view class="product-info">
        <!-- 商品名称 -->
        <text class="product-name">{{item.name}}</text>

        <!-- 香型标签 -->
        <view class="product-aroma-tag" wx:if="{{item.categoryName}}">
          <text>{{item.categoryName}}型</text>
        </view>

        <!-- 包装类型 -->
        <view class="product-pack-row" wx:if="{{item.tags && item.tags.length > 0}}">
          <text
            class="product-pack-tag"
            wx:for="{{item.tags}}"
            wx:for-item="tag"
            wx:key="*this"
            wx:if="{{tag.indexOf('袋装') > -1 || tag.indexOf('铁罐') > -1 || tag.indexOf('礼盒') > -1}}"
          >{{tag}}</text>
        </view>

        <!-- 标签 -->
        <view class="product-tags-row" wx:if="{{item.tags && item.tags.length > 0}}">
          <text
            class="product-label"
            wx:for="{{item.tags}}"
            wx:for-item="tag"
            wx:key="*this"
            wx:if="{{tag.indexOf('袋装') === -1 && tag.indexOf('铁罐') === -1 && tag.indexOf('礼盒') === -1 && index < 3}}"
          >{{tag}}</text>
        </view>

        <!-- 价格 -->
        <view class="product-meta">
          <view class="product-price-group">
            <text class="product-price-symbol">¥</text>
            <text class="product-price">{{item.price}}</text>
            <text class="product-original-price" wx:if="{{item.originalPrice && item.originalPrice > item.price}}">¥{{item.originalPrice}}</text>
          </view>
          <text class="product-weight" wx:if="{{item.weight}}">{{item.weight}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 5. 空状态 ========== -->
  <view class="empty-state" wx:if="{{!isLoading && products.length === 0}}">
    <view class="empty-icon-wrap">
      <view class="empty-cup"></view>
    </view>
    <text class="empty-text">暂无相关茶品</text>
    <text class="empty-hint">换个分类看看吧</text>
  </view>

  <!-- ========== 6. 加载状态 ========== -->
  <view class="loading-state" wx:if="{{isLoading}}">
    <view class="loading-dots">
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
    </view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 没有更多 -->
  <view class="no-more" wx:if="{{!isLoading && products.length > 0 && !hasMore}}">
    <view class="no-more-line"></view>
    <text class="no-more-text">没有更多了</text>
    <view class="no-more-line"></view>
  </view>

  <!-- 底部留白 -->
  <view class="footer-space"></view>
</view>
