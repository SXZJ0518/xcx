<view class="page">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">茶品</text>
    <text class="page-subtitle">高山炭焙 · 传统工艺</text>
  </view>

  <!-- 香型筛选 -->
  <scroll-view class="filter-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
    <view class="filter-list">
      <view class="filter-item {{currentCategory === '' ? 'active' : ''}}" bindtap="filterCategory" data-id="">全部</view>
      <view class="filter-item {{currentCategory === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="filterCategory" data-id="{{item.id}}">
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 商品列表 -->
  <view class="product-list">
    <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="product-image">
        <image src="{{item.imageUrl || '/images/tea-placeholder.png'}}" mode="aspectFill" lazy-load="true"></image>
        <view class="product-tag" wx:if="{{item.isNew}}">新品</view>
      </view>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <text class="product-brief">{{item.brief}}</text>
        <view class="product-meta">
          <text class="product-price">¥{{item.price}}</text>
          <text class="product-weight">{{item.weight}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
    <text class="empty-icon">🍵</text>
    <text class="empty-text">暂无茶品</text>
  </view>

  <!-- 底部留白 -->
  <view class="footer-space"></view>
</view>
