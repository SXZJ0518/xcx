/* ============================================================
   茶品列表页样式 - 东方禅意美学
   主色 #c9a86c | 背景 #f5f0e8 | 文字 #2d2520
   ============================================================ */

.page {
  min-height: 100vh;
  background: #f5f0e8;
}

/* ========== 1. 顶部搜索栏 ========== */
.search-bar-wrap {
  padding: 20rpx 30rpx;
}

.search-bar-inner {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 28rpx;
  background: #fff;
  border-radius: 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 37, 32, 0.05);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  position: relative;
}

.icon-search-dot {
  position: absolute;
  top: 0;
  left: 0;
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid #8b7355;
  border-radius: 50%;
}

.icon-search-line {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 14rpx;
  height: 3rpx;
  background: #8b7355;
  border-radius: 2rpx;
  transform: rotate(45deg);
  transform-origin: top right;
}

.search-placeholder {
  font-size: 26rpx;
  color: #a09080;
  letter-spacing: 2rpx;
}

/* ========== 2. 分类标签栏 ========== */
.category-tabs {
  display: flex;
  padding: 10rpx 30rpx 20rpx;
  gap: 20rpx;
}

.category-tab {
  padding: 14rpx 40rpx;
  font-size: 28rpx;
  color: #5a5045;
  background: #fff;
  border-radius: 30rpx;
  border: 1rpx solid #e8e0d5;
  transition: all 0.3s;
  letter-spacing: 2rpx;
}

.category-tab.active {
  color: #c9a86c;
  background: rgba(201, 168, 108, 0.1);
  border-color: #c9a86c;
  font-weight: 500;
}

/* ========== 3. 筛选栏 ========== */
.filter-bar {
  padding: 0 30rpx 24rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 24rpx;
  color: #8b7355;
  margin-right: 20rpx;
  letter-spacing: 2rpx;
  min-width: 56rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-option {
  padding: 8rpx 24rpx;
  font-size: 22rpx;
  color: #5a5045;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid #e8e0d5;
  transition: all 0.3s;
  letter-spacing: 1rpx;
}

.filter-option.active {
  color: #c9a86c;
  background: rgba(201, 168, 108, 0.08);
  border-color: #c9a86c;
}

/* ========== 4. 商品网格（2列） ========== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
}

.product-card {
  position: relative;
  width: calc(50% - 20rpx);
  margin: 0 10rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(45, 37, 32, 0.06);
  transition: transform 0.3s;
}

.product-card:active {
  transform: scale(0.98);
}

/* 特惠角标 */
.special-badge {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 3;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #c9a86c, #a08050);
  color: #fff;
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  border-radius: 0 16rpx 0 16rpx;
}

.new-badge {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 3;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #5a5045, #3d3530);
  color: #c9a86c;
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  border-radius: 0 16rpx 0 16rpx;
}

.product-image {
  position: relative;
  width: 100%;
  height: 260rpx;
  background: #f0ebe0;
  overflow: hidden;
}

.product-image image {
  width: 100%;
  height: 100%;
}

.product-info {
  padding: 20rpx;
}

/* 商品名称 */
.product-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #2d2520;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 1rpx;
}

/* 香型标签 */
.product-aroma-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: rgba(201, 168, 108, 0.12);
  border-radius: 6rpx;
  margin-bottom: 10rpx;
}

.product-aroma-tag text {
  font-size: 20rpx;
  color: #a08050;
  letter-spacing: 1rpx;
}

/* 包装类型 */
.product-pack-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.product-pack-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 18rpx;
  color: #5a5045;
  background: #f5f0e8;
  border-radius: 6rpx;
  letter-spacing: 1rpx;
}

/* 标签行 */
.product-tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
  gap: 8rpx;
}

.product-label {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 18rpx;
  color: #8b7355;
  background: rgba(201, 168, 108, 0.08);
  border-radius: 6rpx;
  letter-spacing: 1rpx;
}

/* 价格区域 */
.product-meta {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.product-price-group {
  display: flex;
  align-items: baseline;
}

.product-price-symbol {
  font-size: 22rpx;
  font-weight: 600;
  color: #b8860b;
}

.product-price {
  font-size: 34rpx;
  font-weight: 600;
  color: #b8860b;
}

.product-original-price {
  font-size: 22rpx;
  color: #a09080;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.product-weight {
  font-size: 20rpx;
  color: #a09080;
}

/* ========== 5. 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0 80rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-cup {
  width: 80rpx;
  height: 60rpx;
  border: 4rpx solid #d5cfc5;
  border-radius: 0 0 40rpx 40rpx;
  position: relative;
}

.empty-cup::before {
  content: '';
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid #d5cfc5;
  border-radius: 50%;
  opacity: 0.6;
}

.empty-cup::after {
  content: '';
  position: absolute;
  top: -36rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 10rpx;
  border: 2rpx solid #d5cfc5;
  border-radius: 50%;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  color: #5a5045;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #a09080;
  letter-spacing: 1rpx;
}

/* ========== 6. 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  background: #c9a86c;
  border-radius: 50%;
  opacity: 0.3;
  animation: loadingPulse 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes loadingPulse {
  0%, 100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.loading-text {
  font-size: 24rpx;
  color: #a09080;
  letter-spacing: 2rpx;
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 60rpx;
}

.no-more-line {
  flex: 1;
  height: 1rpx;
  background: #e8e0d5;
}

.no-more-text {
  padding: 0 24rpx;
  font-size: 22rpx;
  color: #a09080;
  letter-spacing: 2rpx;
}

/* ========== 底部留白 ========== */
.footer-space {
  height: 60rpx;
}
