/* ============================================================
   茶品列表页样式 - 整页连续滚动，左侧导航自动高亮
   ============================================================ */

page {
  --ink:     #2d2520;
  --earth:   #5a5045;
  --bark:    #8b7355;
  --gold:    #c9a86c;
  --gold-d:  #a08050;
  --cream:   #f5f0e8;
  --paper:   #faf7f0;
  --white:   #ffffff;
  --shadow:  rgba(45, 37, 32, 0.06);
  --radius:  16rpx;
  --gap:     20rpx;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--cream);
}

/* ==================== 顶部搜索栏 ==================== */
.search-bar-wrap {
  flex-shrink: 0;
  padding: 20rpx 30rpx;
  background: var(--cream);
}

.search-bar-inner {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 28rpx;
  background: var(--white);
  border-radius: 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 37, 32, 0.05);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  position: relative;
}

.icon-search-dot {
  position: absolute;
  top: 0;
  left: 0;
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid var(--bark);
  border-radius: 50%;
}

.icon-search-line {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 14rpx;
  height: 3rpx;
  background: var(--bark);
  border-radius: 2rpx;
  transform: rotate(45deg);
  transform-origin: top right;
}

.search-placeholder {
  font-size: 26rpx;
  color: #a09080;
  letter-spacing: 2rpx;
}

/* ==================== 主体区域 ==================== */
.main-body {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* ==================== 左侧导航（固定） ==================== */
.side-nav {
  width: 180rpx;
  flex-shrink: 0;
  background: var(--paper);
  border-right: 1rpx solid rgba(201, 168, 108, 0.1);
  position: relative;
  z-index: 10;
}

.nav-item {
  position: relative;
  display: flex;
  align-items: center;
  padding: 36rpx 20rpx;
  transition: all 0.25s ease;
  background: transparent;
}

.nav-item.active {
  background: var(--white) !important;
}

.nav-line {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: var(--gold);
  border-radius: 0 3rpx 3rpx 0;
  z-index: 1;
}

.nav-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--bark);
  letter-spacing: 2rpx;
  line-height: 1.4;
}

.nav-item.active .nav-text {
  color: var(--ink) !important;
  font-weight: 600 !important;
}

/* ==================== 右侧滚动区域 ==================== */
.product-scroll {
  flex: 1;
  height: 100%;
  background: var(--cream);
}

.product-scroll-inner {
  padding: var(--gap);
}

/* ==================== 分类区块 ==================== */
.category-section {
  margin-bottom: 0;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 20rpx 0 24rpx;
}

.section-mark {
  width: 6rpx;
  height: 28rpx;
  background: var(--gold);
  border-radius: 3rpx;
  margin-right: 14rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  letter-spacing: 4rpx;
}

.section-desc {
  font-size: 22rpx;
  color: var(--bark);
  margin-left: 16rpx;
  letter-spacing: 2rpx;
}

/* ==================== 商品卡片 ==================== */
.section-products {
  display: flex;
  flex-direction: column;
  gap: var(--gap);
}

.p-card {
  display: flex;
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx var(--shadow);
  transition: transform 0.2s ease;
}

.p-card:active {
  transform: scale(0.99);
}

.p-image {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #ede6d9 0%, #dbd1c0 100%);
  overflow: hidden;
}

.p-image image {
  width: 100%;
  height: 100%;
}

.p-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(45, 37, 32, 0.08), transparent 50%);
  pointer-events: none;
}

.p-tag-special {
  position: absolute;
  top: 0;
  left: 0;
  padding: 8rpx 18rpx;
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  border-radius: 0 0 16rpx 0;
  font-size: 20rpx;
  font-weight: 500;
  color: var(--white);
  letter-spacing: 2rpx;
}

.p-tag-new {
  position: absolute;
  top: 0;
  left: 0;
  padding: 8rpx 18rpx;
  background: linear-gradient(135deg, var(--ink), #3d3530);
  border-radius: 0 0 16rpx 0;
  font-size: 20rpx;
  font-weight: 500;
  color: var(--gold);
  letter-spacing: 2rpx;
}

.p-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24rpx 28rpx;
  justify-content: space-between;
}

.p-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ink);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.p-brief {
  font-size: 22rpx;
  color: var(--bark);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.p-aroma-row {
  margin-bottom: 16rpx;
}

.p-aroma {
  display: inline-block;
  padding: 6rpx 18rpx;
  background: rgba(201, 168, 108, 0.12);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: var(--gold-d);
  letter-spacing: 2rpx;
}

.p-price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.p-price-box {
  display: flex;
  align-items: baseline;
}

.p-symbol {
  font-size: 24rpx;
  font-weight: 600;
  color: #b8860b;
  margin-right: 2rpx;
}

.p-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #b8860b;
  line-height: 1;
}

.p-original {
  font-size: 22rpx;
  color: #a09080;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.p-weight {
  font-size: 22rpx;
  color: var(--bark);
  background: var(--cream);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* ==================== 分类间距 ==================== */
.section-gap {
  height: 40rpx;
  background: transparent;
}

/* ==================== 空状态 ==================== */
.section-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.section-empty-text {
  font-size: 24rpx;
  color: var(--bark);
  letter-spacing: 2rpx;
}

/* ==================== 敬请期待 ==================== */
.coming-soon {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  border: 2rpx dashed rgba(201, 168, 108, 0.2);
  border-radius: var(--radius);
  margin-bottom: 20rpx;
}

.coming-soon-text {
  font-size: 26rpx;
  color: var(--bark);
  letter-spacing: 4rpx;
}

/* ==================== 加载更多 ==================== */
.loading-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--gold);
  border-radius: 50%;
  opacity: 0.3;
  animation: dotPulse 1.2s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* ==================== 底部留白 ==================== */
.list-footer {
  height: 60rpx;
}
