<!-- 登录页面 -->
<view class="page">
  <!-- 背景装饰 -->
  <view class="bg-deco">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
    <view class="bg-circle bg-circle-3"></view>
  </view>

  <!-- Logo 区域 -->
  <view class="logo-section">
    <view class="logo-wrap">
      <text class="logo-icon">🍃</text>
    </view>
    <text class="logo-title">凤凰单枞</text>
    <text class="logo-slogan">一丛一味 · 百丛百香</text>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <view class="login-section">
      <view class="section-title">
        <view class="title-line"></view>
        <text>微信登录</text>
        <view class="title-line"></view>
      </view>
      <button class="wx-login-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
        <view class="btn-icon">📱</view>
        <text class="btn-text">微信手机号快捷登录</text>
      </button>
      <button class="wx-auth-btn" bindtap="onWechatAuth">
        <view class="btn-icon">💬</view>
        <text class="btn-text">微信授权登录</text>
      </button>
    </view>
  </view>

  <!-- 协议 -->
  <view class="agreement">
    <view class="checkbox-wrap" bindtap="toggleAgreement">
      <view class="checkbox {{agreed ? 'checked' : ''}}">
        <text wx:if="{{agreed}}">✓</text>
      </view>
    </view>
    <text class="agreement-text">登录即代表同意</text>
    <text class="agreement-link" bindtap="goToUserAgreement">《用户协议》</text>
    <text class="agreement-text">和</text>
    <text class="agreement-link" bindtap="goToPrivacyPolicy">《隐私政策》</text>
  </view>

  <!-- 底部 -->
  <view class="footer">
    <text class="footer-text">登录后可享受更多专属服务</text>
  </view>
</view>
