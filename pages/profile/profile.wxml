<view class="page">
  <!-- 用户区域 -->
  <view class="user-header">
    <view class="user-bg"></view>
    <view class="user-content">
      <view class="avatar-wrap">
        <image class="avatar" src="/images/default-avatar.png" mode="aspectFill"></image>
      </view>
      <text class="nickname">茶友</text>
      <text class="user-desc">品茶悟道，静心修行</text>
    </view>
  </view>

  <!-- 联系方式卡片 -->
  <view class="contact-card">
    <view class="contact-item" bindtap="copyWechat">
      <view class="contact-icon-wrap wechat-icon">
        <text class="contact-icon-text">微</text>
      </view>
      <view class="contact-info">
        <text class="contact-label">微信号</text>
        <text class="contact-value">{{siteConfig.wechat || '暂未设置'}}</text>
      </view>
      <view class="contact-action">
        <text class="action-text">复制</text>
      </view>
    </view>

    <view class="contact-item" bindtap="callPhone">
      <view class="contact-icon-wrap phone-icon">
        <text class="contact-icon-text">电</text>
      </view>
      <view class="contact-info">
        <text class="contact-label">电话</text>
        <text class="contact-value">{{siteConfig.phone || '暂未设置'}}</text>
      </view>
      <view class="contact-action">
        <text class="action-text">拨打</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="goToAbout">
      <view class="menu-left">
        <view class="menu-icon about-icon"></view>
        <text class="menu-label">关于我们</text>
      </view>
      <text class="menu-arrow">→</text>
    </view>

    <view class="menu-item" bindtap="goToCulture">
      <view class="menu-left">
        <view class="menu-icon culture-icon"></view>
        <text class="menu-label">茶知识</text>
      </view>
      <text class="menu-arrow">→</text>
    </view>

    <button class="menu-item menu-btn" open-type="share">
      <view class="menu-left">
        <view class="menu-icon share-icon"></view>
        <text class="menu-label">分享给朋友</text>
      </view>
      <text class="menu-arrow">→</text>
    </button>
  </view>

  <!-- 品牌信息底部 -->
  <view class="brand-footer">
    <text class="brand-name">{{siteConfig.brandName || '凤凰单枞'}}</text>
    <text class="brand-address">{{siteConfig.address || '广东省潮州市凤凰山'}}</text>
    <text class="brand-copyright">一丛一味 · 百丛百香</text>
  </view>
</view>
