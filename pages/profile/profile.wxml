<view class="page">

  <!-- ========== 1. 顶部用户区域 ========== -->
  <view class="user-header">
    <view class="user-bg">
      <view class="user-bg-grain"></view>
      <view class="user-bg-circle user-bg-circle-1"></view>
      <view class="user-bg-circle user-bg-circle-2"></view>
      <view class="user-bg-circle user-bg-circle-3"></view>
    </view>
    <view class="user-content">
      <!-- 未登录状态 -->
      <block wx:if="{{!isLoggedIn}}">
        <view class="avatar-wrap" bindtap="goToLogin">
          <view class="avatar-default">
            <view class="avatar-icon">
              <view class="avatar-head"></view>
              <view class="avatar-body"></view>
            </view>
          </view>
          <view class="avatar-ring"></view>
        </view>
        <text class="nickname login-hint" bindtap="goToLogin">点击登录</text>
        <text class="user-desc">登录后享受更多专属服务</text>
      </block>
      <!-- 已登录状态 -->
      <block wx:else>
        <view class="avatar-wrap">
          <image wx:if="{{userInfo.avatar}}" class="avatar-img" src="{{userInfo.avatar}}" mode="aspectFill" />
          <view wx:else class="avatar-default">
            <view class="avatar-icon">
              <view class="avatar-head"></view>
              <view class="avatar-body"></view>
            </view>
          </view>
          <view class="avatar-ring"></view>
        </view>
        <text class="nickname">{{userInfo.nickname || '茶友'}}</text>
        <text class="user-desc" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</text>
        <text class="user-desc" wx:else>欢迎回来</text>
      </block>
    </view>
    <!-- 退出登录按钮 -->
    <view class="logout-btn" wx:if="{{isLoggedIn}}" bindtap="logout">
      <text>退出</text>
    </view>
    <!-- 底部弧形过渡 -->
    <view class="header-curve"></view>
  </view>

  <!-- ========== 2. 品牌故事卡片 ========== -->
  <view class="story-card" wx:if="{{siteConfig.about}}">
    <view class="story-header">
      <view class="story-deco"></view>
      <text class="story-title">品牌故事</text>
      <view class="story-deco"></view>
    </view>
    <text class="story-text">{{siteConfig.about}}</text>
    <view class="story-footer">
      <view class="story-divider"></view>
      <text class="story-slogan">{{siteConfig.slogan || '一丛一味 · 百丛百香'}}</text>
    </view>
  </view>

  <!-- ========== 4. 功能菜单 ========== -->
  <view class="menu-card">
    <view class="menu-item" bindtap="goToFavorites">
      <view class="menu-left">
        <view class="menu-icon-wrap fav-bg">
          <text class="menu-icon-text">藏</text>
        </view>
        <view class="menu-text-wrap">
          <text class="menu-label">我的收藏</text>
          <text class="menu-desc">{{favoriteCount > 0 ? '已收藏 ' + favoriteCount + ' 款茶品' : '暂无收藏'}}</text>
        </view>
      </view>
      <view class="menu-arrow-wrap">
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="goToAbout">
      <view class="menu-left">
        <view class="menu-icon-wrap about-bg">
          <text class="menu-icon-text">源</text>
        </view>
        <view class="menu-text-wrap">
          <text class="menu-label">关于我们</text>
          <text class="menu-desc">了解凤凰单枞的故事</text>
        </view>
      </view>
      <view class="menu-arrow-wrap">
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-item menu-item-share">
      <button class="share-trigger" open-type="share"></button>
      <view class="menu-left">
        <view class="menu-icon-wrap share-bg">
          <text class="menu-icon-text">享</text>
        </view>
        <view class="menu-text-wrap">
          <text class="menu-label">分享给朋友</text>
          <text class="menu-desc">把好茶推荐给更多人</text>
        </view>
      </view>
      <view class="menu-arrow-wrap">
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- ========== 5. 联系信息卡片 ========== -->
  <view class="info-card" wx:if="{{siteConfig.address || siteConfig.phone}}">
    <view class="info-row" wx:if="{{siteConfig.address}}">
      <text class="info-label">📍 产地</text>
      <text class="info-value">{{siteConfig.address}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">📦 发货地</text>
      <text class="info-value">广东 · 汕头</text>
    </view>
    <view class="info-row" wx:if="{{siteConfig.phone}}">
      <text class="info-label">📞 电话</text>
      <text class="info-value">{{siteConfig.phone}}</text>
    </view>
    <view class="info-row" wx:if="{{siteConfig.wechat}}">
      <text class="info-label">💬 微信</text>
      <text class="info-value">{{siteConfig.wechat}}</text>
    </view>
  </view>

  <!-- ========== 6. 底部 ========== -->
  <view class="page-footer">
    <view class="footer-brand">
      <view class="footer-brand-dot"></view>
      <text class="footer-brand-name">{{siteConfig.brandName || '凤凰单枞'}}</text>
      <view class="footer-brand-dot"></view>
    </view>
    <text class="footer-version">v1.0.0</text>
  </view>

</view>
