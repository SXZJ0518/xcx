/* ============================================================
   我的页面 - 东方禅意 × 现代质感
   主色 #c9a86c | 背景 #f5f0e8 | 文字 #2d2520
   ============================================================ */

.page {
  min-height: 100vh;
  background: #f5f0e8;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==================== 1. 顶部用户区域 ==================== */
.user-header {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.user-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(165deg, #1e1a16 0%, #2d2520 40%, #3a322c 100%);
}

/* 纹理 */
.user-bg-grain {
  position: absolute;
  inset: 0;
  opacity: 0.03;
  background:
    repeating-linear-gradient(0deg, transparent, transparent 2rpx, #fff 2rpx, #fff 3rpx),
    repeating-linear-gradient(90deg, transparent, transparent 2rpx, #fff 2rpx, #fff 3rpx);
}

/* 装饰圆环 */
.user-bg-circle {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(201, 168, 108, 0.08);
}
.user-bg-circle-1 {
  width: 500rpx;
  height: 500rpx;
  top: -200rpx;
  right: -160rpx;
}
.user-bg-circle-2 {
  width: 320rpx;
  height: 320rpx;
  bottom: -80rpx;
  left: -100rpx;
  border-color: rgba(201, 168, 108, 0.05);
}
.user-bg-circle-3 {
  width: 180rpx;
  height: 180rpx;
  top: 60rpx;
  left: 40rpx;
  border-color: rgba(201, 168, 108, 0.06);
}

.user-content {
  position: relative;
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  height: 100%;
  padding: 60rpx 40rpx 60rpx;
}

/* 头像 */
.avatar-wrap {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  margin-bottom: 24rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.login-hint {
  color: #c9a86c !important;
}

.logout-btn {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  z-index: 10;
}

.logout-btn text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.avatar-default {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(145deg, #3d3530 0%, #4a4038 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-icon {
  position: relative;
  width: 60rpx;
  height: 60rpx;
}

.avatar-head {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: rgba(201, 168, 108, 0.45);
}

.avatar-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 46rpx;
  height: 22rpx;
  border-radius: 23rpx 23rpx 0 0;
  background: rgba(201, 168, 108, 0.45);
}

/* 头像外圈 */
.avatar-ring {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(201, 168, 108, 0.3);
  animation: ringRotate 12s linear infinite;
}

.avatar-ring::before {
  content: '';
  position: absolute;
  top: -3rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #c9a86c;
}

@keyframes ringRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.nickname {
  font-size: 36rpx;
  font-weight: 400;
  color: #c9a86c;
  letter-spacing: 8rpx;
  margin-bottom: 10rpx;
}

.user-desc {
  font-size: 22rpx;
  color: rgba(201, 168, 108, 0.5);
  letter-spacing: 6rpx;
}

/* 底部弧形过渡 */
.header-curve {
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 40rpx;
  background: #f5f0e8;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 3;
}

/* ==================== 2. 快捷操作栏 ==================== */
.quick-bar {
  display: flex;
  justify-content: space-around;
  padding: 36rpx 20rpx 28rpx;
  margin: 30rpx 30rpx 0;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(45, 37, 32, 0.07);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  flex: 1;
}

.quick-item:active {
  opacity: 0.7;
}

/* 分享按钮重置 */
.quick-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  font-size: inherit;
}

.quick-btn::after {
  border: none;
}

.quick-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.quick-icon {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-icon-inner {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
}

.wechat-bg {
  background: linear-gradient(145deg, #07c160, #06ad56);
}

.phone-bg {
  background: linear-gradient(145deg, #4a90d9, #357abd);
}

.about-quick-bg {
  background: linear-gradient(145deg, #c9a86c, #a08050);
}

.share-quick-bg {
  background: linear-gradient(145deg, #5a7a9b, #3a5a7b);
}

.quick-label {
  font-size: 22rpx;
  color: #5a5045;
  letter-spacing: 2rpx;
}

/* ==================== 3. 品牌故事卡片 ==================== */
.story-card {
  margin: 24rpx 30rpx 0;
  padding: 36rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 37, 32, 0.05);
  position: relative;
  overflow: hidden;
}

.story-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #c9a86c, transparent);
}

.story-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.story-deco {
  width: 40rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #c9a86c);
}

.story-deco:last-child {
  background: linear-gradient(90deg, #c9a86c, transparent);
}

.story-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2d2520;
  letter-spacing: 8rpx;
}

.story-text {
  display: block;
  font-size: 24rpx;
  color: #6b6055;
  line-height: 2;
  letter-spacing: 1rpx;
  text-align: justify;
}

.story-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 28rpx;
}

.story-divider {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #c9a86c, transparent);
  margin-bottom: 16rpx;
}

.story-slogan {
  font-size: 22rpx;
  color: #a09080;
  letter-spacing: 4rpx;
}

/* ==================== 4. 功能菜单 ==================== */
.menu-card {
  margin: 24rpx 30rpx 0;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 37, 32, 0.05);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  background: transparent;
  border: none;
  line-height: 1.6;
  text-align: left;
  transition: background 0.2s;
}

.menu-item::after {
  border: none;
}

.menu-item:active {
  background: #faf6ee;
}

.menu-item + .menu-item {
  border-top: 1rpx solid #ede6da;
}

/* 分享的行：用透明 button 覆盖在 view 上捕获分享事件 */
.menu-item-share {
  position: relative;
}

.share-trigger {
  position: absolute;
  inset: 0;
  z-index: 2;
  opacity: 0;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
}

.share-trigger::after {
  border: none;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.about-bg {
  background: linear-gradient(145deg, #c9a86c, #a08050);
}

.fav-bg {
  background: linear-gradient(145deg, #e8785a, #d45a3a);
}

.aroma-bg {
  background: linear-gradient(145deg, #8b6e4e, #6b5030);
}

.share-bg {
  background: linear-gradient(145deg, #5a7a9b, #3a5a7b);
}

.menu-icon-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.menu-text-wrap {
  display: flex;
  flex-direction: column;
}

.menu-label {
  font-size: 28rpx;
  color: #2d2520;
  letter-spacing: 2rpx;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #a09080;
  letter-spacing: 1rpx;
}

.menu-arrow-wrap {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-arrow {
  font-size: 36rpx;
  color: #c9a86c;
  opacity: 0.4;
}

/* ==================== 5. 联系信息卡片 ==================== */
.info-card {
  margin: 24rpx 30rpx 0;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 37, 32, 0.05);
}

.info-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid #ede6da;
}

.info-label {
  font-size: 24rpx;
  color: #8b7355;
  width: 160rpx;
  flex-shrink: 0;
  letter-spacing: 2rpx;
}

.info-value {
  font-size: 24rpx;
  color: #2d2520;
  flex: 1;
  letter-spacing: 1rpx;
}

/* ==================== 6. 底部 ==================== */
.page-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.footer-brand-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #c9a86c;
  opacity: 0.5;
}

.footer-brand-name {
  font-size: 28rpx;
  font-weight: 400;
  color: #2d2520;
  letter-spacing: 6rpx;
}

.footer-version {
  font-size: 20rpx;
  color: #b0a090;
  letter-spacing: 2rpx;
}
