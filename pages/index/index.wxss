/* ============================================================
   首页样式 — 侘寂茶美学
   设计原则：留白即呼吸 | 一字一天地 | 色不过三 | 饰不过度

   色系：
   --tea-ink:    #2d2520   茶墨（最深文字）
   --tea-earth:  #5a5045   茶土（正文）
   --tea-bark:   #8b7355   茶枝（辅助）
   --tea-gold:   #c9a86c   茶金（点缀）
   --tea-cream:  #f5f0e8   茶乳（背景）
   --tea-paper:  #faf7f0   茶纸（卡片底）
   ============================================================ */

/* ==================== 基础变量 ==================== */
page {
  --ink:     #2d2520;
  --earth:   #5a5045;
  --bark:    #8b7355;
  --gold:    #c9a86c;
  --gold-d:  #a08050;
  --cream:   #f5f0e8;
  --paper:   #faf7f0;
  --white:   #ffffff;
  --shadow:  rgba(45, 37, 32, 0.06);
  --radius:  20rpx;
  --gap:     24rpx;
}

.page {
  min-height: 100vh;
  background: var(--cream);
  overflow-x: hidden;
}

/* ==================== 1. HERO ==================== */
.hero {
  position: relative;
  width: 100%;
  height: 560rpx;
  overflow: hidden;
}

/* 背景层 */
.hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(170deg, #1a1512 0%, #2d2520 35%, #3a322c 65%, #2d2520 100%);
}

/* 纹理 */
.hero-grain {
  position: absolute;
  inset: 0;
  opacity: 0.04;
  background:
    repeating-linear-gradient(0deg, transparent, transparent 2rpx, #fff 2rpx, #fff 3rpx),
    repeating-linear-gradient(90deg, transparent, transparent 2rpx, #fff 2rpx, #fff 3rpx);
}

/* 装饰圆环 */
.hero-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(201, 168, 108, 0.12);
}
.hero-ring-1 {
  width: 420rpx;
  height: 420rpx;
  top: -160rpx;
  right: -120rpx;
}
.hero-ring-2 {
  width: 280rpx;
  height: 280rpx;
  bottom: -100rpx;
  left: -80rpx;
  border-color: rgba(201, 168, 108, 0.08);
}

/* 茶叶意象 - 用CSS绘制的极简茶叶形状 */
.hero-leaf {
  position: absolute;
  opacity: 0.06;
}
.hero-leaf::before,
.hero-leaf::after {
  content: '';
  position: absolute;
  width: 80rpx;
  height: 160rpx;
  background: var(--gold);
  border-radius: 50% 0 50% 0;
  transform-origin: center center;
}
.hero-leaf-tl {
  top: 40rpx;
  left: 20rpx;
}
.hero-leaf-tl::before {
  transform: rotate(-15deg);
}
.hero-leaf-tl::after {
  transform: rotate(25deg) translateX(10rpx);
  opacity: 0.6;
}
.hero-leaf-br {
  bottom: 30rpx;
  right: 40rpx;
}
.hero-leaf-br::before {
  transform: rotate(160deg);
  width: 60rpx;
  height: 120rpx;
}

/* 内容层 */
.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 40rpx 60rpx;
}

.hero-kicker {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}
.hero-kicker text {
  font-size: 24rpx;
  color: rgba(201, 168, 108, 0.6);
  letter-spacing: 8rpx;
}
.hero-dot {
  color: var(--gold) !important;
  margin-right: 4rpx;
  font-size: 20rpx !important;
}

.hero-brand {
  font-size: 88rpx;
  font-weight: 200;
  color: var(--gold);
  letter-spacing: 28rpx;
  text-indent: 28rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
  margin-bottom: 24rpx;
}

.hero-divider {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin-bottom: 28rpx;
}

.hero-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  letter-spacing: 10rpx;
  text-indent: 10rpx;
}

/* 滚动提示动画 */
.hero-scroll-hint {
  position: absolute;
  bottom: 32rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.hero-scroll-line {
  width: 2rpx;
  height: 36rpx;
  background: linear-gradient(to bottom, rgba(201, 168, 108, 0.4), transparent);
  animation: heroPulse 2s ease-in-out infinite;
}
@keyframes heroPulse {
  0%, 100% { opacity: 0.4; height: 36rpx; }
  50%      { opacity: 0.8; height: 48rpx; }
}

/* ==================== 通用 Section ==================== */
.section {
  padding: 60rpx 0 0;
}

.sec-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 30rpx 36rpx;
}

.sec-head-left {
  display: flex;
  align-items: center;
}

.sec-mark {
  width: 6rpx;
  height: 28rpx;
  background: var(--gold);
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.sec-title {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: 4rpx;
}

.sec-subtitle {
  font-size: 22rpx;
  color: var(--bark);
  margin-left: 16rpx;
  letter-spacing: 2rpx;
}

.sec-head-right {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--bark);
}
.sec-arrow {
  font-size: 32rpx;
  margin-left: 4rpx;
  color: var(--gold);
  line-height: 1;
}

/* ==================== 2. 热销推荐 - 商品网格 ==================== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 30rpx;
  gap: var(--gap);
}

.p-card {
  width: calc(50% - 12rpx);
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx var(--shadow);
  transition: transform 0.25s ease;
}
.p-card:active {
  transform: scale(0.97);
}

/* 图片区 */
.p-img {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, #ede6d9 0%, #dbd1c0 100%);
  overflow: hidden;
}
.p-img image {
  width: 100%;
  height: 100%;
}
.p-img-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(45, 37, 32, 0.12), transparent 40%);
  pointer-events: none;
}

/* 徽章 */
.p-badge-new {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 6rpx 18rpx;
  background: linear-gradient(135deg, #2d2520, #4a3f38);
  border-radius: 4rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: var(--gold);
  letter-spacing: 2rpx;
  backdrop-filter: blur(10rpx);
}
.p-badge-hot {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  min-width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #b8860b;
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(184, 134, 11, 0.3);
}

/* 信息区 */
.p-body {
  padding: 24rpx 24rpx 28rpx;
}

.p-row-top {
  margin-bottom: 16rpx;
}

.p-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.p-aroma {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  background: rgba(201, 168, 108, 0.1);
  border-radius: 20rpx;
  font-size: 20rpx;
  color: var(--gold-d);
  letter-spacing: 2rpx;
}

.p-row-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.p-price-box {
  display: flex;
  align-items: baseline;
}

.p-symbol {
  font-size: 22rpx;
  font-weight: 600;
  color: #b8860b;
  margin-right: 2rpx;
}

.p-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #b8860b;
  line-height: 1;
}

.p-original {
  font-size: 20rpx;
  color: #a09080;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.p-weight {
  font-size: 20rpx;
  color: var(--bark);
  background: var(--cream);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* ==================== 3. 香型快览 ==================== */
.section-aromas {
  padding-bottom: 0;
}

.aroma-scroll {
  width: 100%;
  white-space: nowrap;
}

.aroma-list {
  display: inline-flex;
  padding: 0 30rpx 16rpx;
}

.a-card {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  width: 200rpx;
  margin-right: 20rpx;
  padding: 32rpx 24rpx 28rpx;
  border-radius: 24rpx;
  background: var(--white);
  box-shadow: 0 4rpx 24rpx var(--shadow);
  transition: transform 0.25s ease;
  position: relative;
  overflow: hidden;
}

.a-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: var(--card-bg, var(--gold));
  opacity: 0.7;
}

.a-card:active {
  transform: scale(0.96);
}

.a-emoji-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: var(--card-bg, var(--cream));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.a-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.a-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.a-desc {
  font-size: 20rpx;
  color: var(--bark);
  white-space: normal;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ==================== 4. 品牌箴言 ==================== */
.brand-quote {
  padding: 80rpx 50rpx;
  position: relative;
}

.bq-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.bq-mark {
  font-size: 72rpx;
  color: var(--gold);
  opacity: 0.2;
  font-weight: 200;
  line-height: 0.6;
  font-family: Georgia, 'Times New Roman', serif;
}
.bq-mark-l {
  align-self: flex-start;
  margin-bottom: -10rpx;
}
.bq-mark-r {
  align-self: flex-end;
  margin-top: -30rpx;
}

.bq-text {
  font-size: 28rpx;
  color: var(--earth);
  line-height: 2.2;
  text-align: center;
  letter-spacing: 3rpx;
  max-width: 500rpx;
}

/* ==================== 5. CTA ==================== */
.cta {
  padding: 0 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.cta-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  background: var(--ink);
  border-radius: 16rpx;
  transition: transform 0.2s, opacity 0.2s;
  position: relative;
  overflow: hidden;
}

.cta-btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 40%, rgba(201, 168, 108, 0.08) 100%);
}

.cta-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.cta-label {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--gold);
  letter-spacing: 6rpx;
  position: relative;
  z-index: 1;
}

.cta-arrow-wrap {
  margin-left: 12rpx;
  position: relative;
  z-index: 1;
}

.cta-arrow {
  font-size: 28rpx;
  color: var(--gold);
}

.cta-extra {
  padding: 16rpx 0;
}
.cta-extra text {
  font-size: 24rpx;
  color: var(--bark);
  letter-spacing: 4rpx;
}

/* ==================== 6. 联系 ==================== */
.contact {
  padding: 0 50rpx;
}

.contact-card {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  background: var(--white);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.03);
  transition: transform 0.2s;
}
.contact-card:active {
  transform: scale(0.99);
}

.contact-avatar {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.contact-avatar-inner {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--ink), #3d3530);
  display: flex;
  align-items: center;
  justify-content: center;
}

.contact-avatar-letter {
  font-size: 28rpx;
  color: var(--gold);
  font-weight: 500;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--ink);
  margin-bottom: 4rpx;
}

.contact-hint {
  font-size: 22rpx;
  color: var(--bark);
}

.contact-action {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  background: rgba(201, 168, 108, 0.08);
  border-radius: 40rpx;
  border: 1rpx solid rgba(201, 168, 108, 0.2);
}

.contact-action-text {
  font-size: 24rpx;
  color: var(--gold);
}

.contact-placeholder {
  height: 40rpx;
}

/* ==================== 底部留白 ==================== */
.footer-space {
  height: 120rpx;
}
