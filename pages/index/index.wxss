/* ============================================================
   首页样式 — 侘寂茶美学
   设计原则：留白即呼吸 | 一字一天地 | 色不过三 | 饰不过度

   色系：
   --tea-ink:    #2d2520   茶墨（最深文字）
   --tea-earth:  #5a5045   茶土（正文）
   --tea-bark:   #8b7355   茶枝（辅助）
   --tea-gold:   #c9a86c   茶金（点缀）
   --tea-cream:  #f5f0e8   茶乳（背景）
   --tea-paper:  #faf7f0   茶纸（卡片底）
   ============================================================ */

/* ==================== 基础变量 ==================== */
page {
  --ink:     #2d2520;
  --earth:   #5a5045;
  --bark:    #8b7355;
  --gold:    #c9a86c;
  --gold-d:  #a08050;
  --cream:   #f5f0e8;
  --paper:   #faf7f0;
  --white:   #ffffff;
  --shadow:  rgba(45, 37, 32, 0.06);
  --radius:  20rpx;
  --gap:     24rpx;
}

.page {
  min-height: 100vh;
  background: var(--cream);
  overflow-x: hidden;
}

/* ==================== 1. 轮播图 ==================== */
.banner-section {
  width: 100%;
  height: 480rpx;
  background: var(--ink);
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-swiper swiper-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.3) 100%);
  pointer-events: none;
}

.banner-content {
  position: absolute;
  bottom: 60rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 2;
}

.banner-title {
  display: block;
  font-size: 40rpx;
  font-weight: 500;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.4);
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.banner-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3);
  letter-spacing: 2rpx;
}

/* 轮播图指示器样式 */
.banner-swiper .wx-swiper-dot {
  width: 16rpx !important;
  height: 4rpx !important;
  border-radius: 2rpx !important;
  background: rgba(255,255,255,0.4) !important;
}

.banner-swiper .wx-swiper-dot-active {
  width: 32rpx !important;
  background: var(--gold) !important;
}

/* ==================== 品牌信息区 ==================== */
.brand-section {
  position: relative;
  width: 100%;
  padding: 60rpx 40rpx;
  background: linear-gradient(170deg, #1a1512 0%, #2d2520 35%, #3a322c 65%, #2d2520 100%);
  overflow: hidden;
}

.brand-section::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0.04;
  background:
    repeating-linear-gradient(0deg, transparent, transparent 2rpx, #fff 2rpx, #fff 3rpx),
    repeating-linear-gradient(90deg, transparent, transparent 2rpx, #fff 2rpx, #fff 3rpx);
}

.brand-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.brand-kicker {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}
.brand-kicker text {
  font-size: 24rpx;
  color: rgba(201, 168, 108, 0.6);
  letter-spacing: 8rpx;
}
.brand-dot {
  color: var(--gold) !important;
  margin-right: 4rpx;
  font-size: 20rpx !important;
}

.brand-name {
  font-size: 72rpx;
  font-weight: 200;
  color: var(--gold);
  letter-spacing: 24rpx;
  text-indent: 24rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
  margin-bottom: 24rpx;
}

.brand-divider {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin-bottom: 28rpx;
}

.brand-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  letter-spacing: 10rpx;
  text-indent: 10rpx;
}

/* ==================== 通用 Section ==================== */
.section {
  padding: 30rpx 0 0;
}

.sec-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 30rpx 36rpx;
}

.sec-head-left {
  display: flex;
  align-items: center;
}

.sec-mark {
  width: 6rpx;
  height: 28rpx;
  background: var(--gold);
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.sec-title {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: 4rpx;
}

.sec-subtitle {
  font-size: 22rpx;
  color: var(--bark);
  margin-left: 16rpx;
  letter-spacing: 2rpx;
}

.sec-head-right {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--bark);
}
.sec-arrow {
  font-size: 32rpx;
  margin-left: 4rpx;
  color: var(--gold);
  line-height: 1;
}

/* ==================== 2. 热销推荐 - 商品网格 ==================== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 30rpx;
  gap: var(--gap);
}

.p-card {
  width: calc(50% - 12rpx);
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx var(--shadow);
  transition: transform 0.25s ease;
}
.p-card:active {
  transform: scale(0.97);
}

/* 图片区 */
.p-img {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, #ede6d9 0%, #dbd1c0 100%);
  overflow: hidden;
}
.p-img image {
  width: 100%;
  height: 100%;
}
.p-img-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(45, 37, 32, 0.12), transparent 40%);
  pointer-events: none;
}

/* 徽章 */
.p-badge-new {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 6rpx 18rpx;
  background: linear-gradient(135deg, #2d2520, #4a3f38);
  border-radius: 4rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: var(--gold);
  letter-spacing: 2rpx;
  backdrop-filter: blur(10rpx);
}
.p-badge-hot {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  min-width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #b8860b;
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(184, 134, 11, 0.3);
}

/* 信息区 */
.p-body {
  padding: 24rpx 24rpx 28rpx;
}

.p-row-top {
  margin-bottom: 16rpx;
}

.p-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.p-aroma {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  background: rgba(201, 168, 108, 0.1);
  border-radius: 20rpx;
  font-size: 20rpx;
  color: var(--gold-d);
  letter-spacing: 2rpx;
}

.p-row-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.p-price-box {
  display: flex;
  align-items: baseline;
}

.p-symbol {
  font-size: 22rpx;
  font-weight: 600;
  color: #b8860b;
  margin-right: 2rpx;
}

.p-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #b8860b;
  line-height: 1;
}

.p-original {
  font-size: 20rpx;
  color: #a09080;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.p-weight {
  font-size: 20rpx;
  color: var(--bark);
  background: var(--cream);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* ==================== 3. 香型快览 ==================== */
.section-aromas {
  padding-bottom: 0;
}

.aroma-scroll {
  width: 100%;
  white-space: nowrap;
}

.aroma-list {
  display: inline-flex;
  padding: 0 30rpx 16rpx;
}

.a-card {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  width: 200rpx;
  margin-right: 20rpx;
  padding: 32rpx 24rpx 28rpx;
  border-radius: 24rpx;
  background: var(--white);
  box-shadow: 0 4rpx 24rpx var(--shadow);
  transition: transform 0.25s ease;
  position: relative;
  overflow: hidden;
}

.a-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: var(--card-bg, var(--gold));
  opacity: 0.7;
}

.a-card:active {
  transform: scale(0.96);
}

.a-emoji-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: var(--card-bg, var(--cream));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.a-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.a-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.a-desc {
  font-size: 20rpx;
  color: var(--bark);
  white-space: normal;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ==================== 3. 茶知识入口 ==================== */
.knowledge-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 36rpx 30rpx 0;
  padding: 24rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 37, 32, 0.05);
  border: 1rpx solid rgba(201, 168, 108, 0.1);
  transition: transform 0.2s;
}

.knowledge-entry:active {
  transform: scale(0.98);
}

.ke-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.ke-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #c9a86c, #a08050);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.ke-icon {
  font-size: 32rpx;
}

.ke-text {
  display: flex;
  flex-direction: column;
}

.ke-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2d2520;
  letter-spacing: 2rpx;
  margin-bottom: 4rpx;
}

.ke-desc {
  font-size: 22rpx;
  color: #a09080;
  letter-spacing: 1rpx;
}

.ke-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.ke-arrow {
  font-size: 22rpx;
  color: #c9a86c;
  letter-spacing: 1rpx;
  font-weight: 500;
}

/* ==================== 6. 品牌箴言 ==================== */
.brand-quote {
  padding: 40rpx 50rpx;
  position: relative;
}

.bq-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.bq-mark {
  font-size: 72rpx;
  color: var(--gold);
  opacity: 0.2;
  font-weight: 200;
  line-height: 0.6;
  font-family: Georgia, 'Times New Roman', serif;
}
.bq-mark-l {
  align-self: flex-start;
  margin-bottom: -10rpx;
}
.bq-mark-r {
  align-self: flex-end;
  margin-top: -30rpx;
}

.bq-text {
  font-size: 28rpx;
  color: var(--earth);
  line-height: 2.2;
  text-align: center;
  letter-spacing: 3rpx;
  max-width: 500rpx;
}

/* ==================== 5. CTA ==================== */
.cta {
  padding: 0 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.cta-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  background: var(--ink);
  border-radius: 16rpx;
  transition: transform 0.2s, opacity 0.2s;
  position: relative;
  overflow: hidden;
}

.cta-btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 40%, rgba(201, 168, 108, 0.08) 100%);
}

.cta-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.cta-label {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--gold);
  letter-spacing: 6rpx;
  position: relative;
  z-index: 1;
}

.cta-arrow-wrap {
  margin-left: 12rpx;
  position: relative;
  z-index: 1;
}

.cta-arrow {
  font-size: 28rpx;
  color: var(--gold);
}

.cta-extra {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border: 2rpx solid rgba(201, 168, 108, 0.5);
  border-radius: 40rpx;
  margin: 0 auto;
}
.cta-extra text {
  font-size: 24rpx;
  color: #8b7355;
  letter-spacing: 4rpx;
}

/* ==================== 6. 联系我们 ==================== */
.contact {
  padding: 0 30rpx;
}

.contact-card {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 37, 32, 0.05);
  border: 1rpx solid rgba(201, 168, 108, 0.1);
  transition: transform 0.2s;
}
.contact-card:active {
  transform: scale(0.99);
}

.contact-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #07c160, #06ad56);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.contact-icon {
  font-size: 32rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2d2520;
  margin-bottom: 6rpx;
  letter-spacing: 2rpx;
}

.contact-wechat {
  font-size: 22rpx;
  color: #8b7355;
  letter-spacing: 1rpx;
}

.contact-action {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  background: rgba(201, 168, 108, 0.1);
  border-radius: 40rpx;
  border: 1rpx solid rgba(201, 168, 108, 0.2);
}

.contact-action-text {
  font-size: 24rpx;
  color: #c9a86c;
}

/* ==================== 联系弹窗 ==================== */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
}

.modal-box {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d2520;
  letter-spacing: 4rpx;
}

.modal-close {
  font-size: 32rpx;
  color: #a09080;
  padding: 10rpx;
}

.modal-body {
  padding: 32rpx;
}

.modal-wechat-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f5f0e8;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.modal-label {
  font-size: 26rpx;
  color: #8b7355;
  letter-spacing: 2rpx;
}

.modal-wechat {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d2520;
  letter-spacing: 2rpx;
}

.modal-copy-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: linear-gradient(135deg, #c9a86c, #b8965c);
  border-radius: 40rpx;
}

.modal-copy-btn:active {
  opacity: 0.85;
}

.modal-copy-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  letter-spacing: 4rpx;
}

.modal-qrcode-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
  padding: 24rpx;
  background: #f5f0e8;
  border-radius: 16rpx;
}

.modal-qrcode {
  width: 320rpx;
  height: 320rpx;
  border-radius: 8rpx;
}

.modal-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx 32rpx;
}

.modal-hint {
  font-size: 22rpx;
  color: #a09080;
  letter-spacing: 2rpx;
}

.contact-placeholder {
  height: 40rpx;
}

/* ==================== 底部留白 ==================== */
.footer-space {
  height: 120rpx;
}
