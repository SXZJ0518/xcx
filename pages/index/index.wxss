/* ============================================================
   首页样式 - 东方禅意美学
   主色 #c9a86c | 背景 #f5f0e8 | 文字 #2d2520
   ============================================================ */

.page {
  min-height: 100vh;
  background: #f5f0e8;
}

/* ========== 1. Hero 大图区域 ========== */
.hero {
  position: relative;
  width: 100%;
  height: 500rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #2d2520 0%, #3d3530 50%, #2d2520 100%);
}

.hero-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="none" stroke="%23c9a86c" stroke-width="0.3" opacity="0.12"/><circle cx="50" cy="50" r="28" fill="none" stroke="%23c9a86c" stroke-width="0.2" opacity="0.08"/></svg>') center/200rpx repeat;
  opacity: 0.6;
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 60rpx 40rpx;
}

.hero-brand {
  font-size: 72rpx;
  font-weight: 300;
  color: #c9a86c;
  letter-spacing: 24rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.hero-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 8rpx;
  margin-bottom: 24rpx;
}

.hero-sub {
  font-size: 22rpx;
  color: rgba(201, 168, 108, 0.7);
  letter-spacing: 4rpx;
}

/* ========== 通用 Section ========== */
.section {
  padding: 50rpx 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #2d2520;
  letter-spacing: 4rpx;
}

.section-more {
  display: flex;
  align-items: center;
}

.section-more text {
  font-size: 24rpx;
  color: #8b7355;
}

.section-more .arrow-right {
  margin-left: 4rpx;
  font-size: 28rpx;
  color: #c9a86c;
}

/* ========== 2. 热销推荐网格 ========== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -12rpx;
}

.product-card {
  width: calc(50% - 24rpx);
  margin: 0 12rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(45, 37, 32, 0.06);
  transition: transform 0.3s;
}

.product-card:active {
  transform: scale(0.98);
}

.product-image {
  position: relative;
  width: 100%;
  height: 280rpx;
  background: #f0ebe0;
  overflow: hidden;
}

.product-image image {
  width: 100%;
  height: 100%;
}

.product-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  background: #c9a86c;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #fff;
  letter-spacing: 2rpx;
}

.product-tag.hot {
  background: #b8860b;
}

.product-info {
  padding: 20rpx 24rpx 24rpx;
}

.product-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #2d2520;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-aroma-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: rgba(201, 168, 108, 0.12);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.product-aroma-tag text {
  font-size: 20rpx;
  color: #a08050;
  letter-spacing: 2rpx;
}

.product-meta {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #b8860b;
}

.product-spec {
  font-size: 20rpx;
  color: #a09080;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag-item {
  font-size: 18rpx;
  color: #8b7355;
  padding: 2rpx 10rpx;
  background: #f5f0e8;
  border-radius: 6rpx;
}

/* ========== 3. 香型快览横向滚动 ========== */
.aroma-scroll {
  width: 100%;
  white-space: nowrap;
}

.aroma-list {
  display: inline-flex;
  padding: 10rpx 0;
}

.aroma-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 180rpx;
  margin-right: 24rpx;
  padding: 30rpx 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 37, 32, 0.06);
  transition: transform 0.3s, box-shadow 0.3s;
}

.aroma-item:active {
  transform: scale(0.96);
}

.aroma-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.aroma-icon {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #c9a86c, #a08050);
  border-radius: 50%;
}

.aroma-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #2d2520;
  margin-bottom: 8rpx;
}

.aroma-desc {
  font-size: 20rpx;
  color: #8b7355;
  text-align: center;
  white-space: normal;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ========== 4. 品牌一句话 ========== */
.brand-quote {
  padding: 60rpx 40rpx;
}

.brand-quote-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-quote-line {
  width: 60rpx;
  height: 2rpx;
  background: #c9a86c;
  margin-bottom: 30rpx;
}

.brand-quote-line:last-child {
  margin-top: 30rpx;
  margin-bottom: 0;
}

.brand-quote-text {
  font-size: 26rpx;
  color: #5a5045;
  line-height: 2;
  text-align: center;
  letter-spacing: 2rpx;
  max-width: 560rpx;
}

/* ========== 5. 底部 CTA 区域 ========== */
.cta-section {
  padding: 20rpx 60rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.cta-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 60rpx;
  border-radius: 50rpx;
  transition: transform 0.3s, box-shadow 0.3s;
}

.cta-btn:active {
  transform: scale(0.97);
}

.cta-btn.primary {
  background: #c9a86c;
  box-shadow: 0 8rpx 24rpx rgba(201, 168, 108, 0.3);
}

.cta-btn.primary .cta-text,
.cta-btn.primary .cta-arrow {
  color: #2d2520;
}

.cta-btn.secondary {
  background: transparent;
  border: 2rpx solid #c9a86c;
}

.cta-btn.secondary .cta-text,
.cta-btn.secondary .cta-arrow {
  color: #c9a86c;
}

.cta-text {
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
}

.cta-arrow {
  font-size: 28rpx;
  margin-left: 8rpx;
}

/* ========== 6. 联系客服区域 ========== */
.contact-section {
  padding: 0 30rpx 40rpx;
  display: flex;
  justify-content: center;
}

.contact-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  background: linear-gradient(135deg, #2d2520 0%, #3d3530 100%);
  border-radius: 50rpx;
  transition: transform 0.3s;
}

.contact-btn:active {
  transform: scale(0.97);
}

.contact-icon-wrap {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.contact-icon {
  width: 36rpx;
  height: 36rpx;
  background: #c9a86c;
  border-radius: 50%;
  position: relative;
}

.contact-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 16rpx;
  border: 2rpx solid #2d2520;
  border-radius: 50%;
}

.contact-text {
  font-size: 26rpx;
  color: #c9a86c;
  letter-spacing: 2rpx;
}

.contact-simple {
  padding: 24rpx 40rpx;
}

.contact-text-simple {
  font-size: 26rpx;
  color: #8b7355;
  letter-spacing: 2rpx;
}

/* ========== 底部留白 ========== */
.footer-space {
  height: 80rpx;
}
