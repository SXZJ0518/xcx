<!-- 
  首页 - 凤凰单枞
  设计：侘寂茶美学 | 留白即呼吸
-->
<view class="page">

  <!-- ========== 1. 轮播图 ========== -->
  <view class="banner-section" wx:if="{{banners.length > 0}}">
    <swiper
      class="banner-swiper"
      indicator-dots="{{true}}"
      autoplay="{{true}}"
      interval="{{4000}}"
      duration="{{500}}"
      circular="{{true}}"
      indicator-color="rgba(255,255,255,0.4)"
      indicator-active-color="#c9a86c"
    >
      <swiper-item
        wx:for="{{banners}}"
        wx:key="id"
        bindtap="onBannerTap"
        data-link="{{item.link}}"
      >
        <image class="banner-image" src="{{item.imageUrl || item.image}}" mode="aspectFill" lazy-load />
        <view class="banner-overlay"></view>
        <view class="banner-content" wx:if="{{item.title}}">
          <text class="banner-title">{{item.title}}</text>
          <text class="banner-desc" wx:if="{{item.description}}">{{item.description}}</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- ========== 2. 茶知识入口 ========== -->
  <view class="knowledge-entry" bindtap="goToKnowledge">
    <view class="ke-left">
      <view class="ke-icon-wrap">
        <text class="ke-icon">📖</text>
      </view>
      <view class="ke-text">
        <text class="ke-title">茶知识</text>
        <text class="ke-desc">品茶文化 · 冲泡技巧 · 茶道美学</text>
      </view>
    </view>
    <view class="ke-right">
      <text class="ke-arrow">阅读全文 ›</text>
    </view>
  </view>

  <!-- ========== 3. 热销推荐 ========== -->
  <view class="section section-products" wx:if="{{hotProducts.length > 0}}">
    <view class="sec-head">
      <view class="sec-head-left">
        <view class="sec-mark"></view>
        <text class="sec-title">热销推荐</text>
      </view>
      <view class="sec-head-right" bindtap="goToProducts">
        <text>看全部</text>
        <text class="sec-arrow">›</text>
      </view>
    </view>

    <view class="product-grid">
      <view
        class="p-card"
        wx:for="{{hotProducts}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="p-img">
          <image src="{{item.imageUrl || item.cover}}" mode="aspectFill" lazy-load />
          <view class="p-badge-new" wx:if="{{item.isNew}}">NEW</view>
          <view class="p-badge-hot" wx:elif="{{item.isHot}}">热</view>
          <view class="p-img-overlay"></view>
        </view>

        <view class="p-body">
          <view class="p-row-top">
            <text class="p-name">{{item.name}}</text>
            <view class="p-aroma" wx:if="{{item.aromaName}}">{{item.aromaName}}</view>
          </view>
          <view class="p-row-bottom">
            <view class="p-price-box">
              <text class="p-symbol">¥</text>
              <text class="p-price">{{item.price}}</text>
              <text class="p-original" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
            </view>
            <text class="p-weight">{{item.weight}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 4. 十大香型 ========== -->
  <view class="section section-aromas" wx:if="{{aromaTypes.length > 0}}">
    <view class="sec-head">
      <view class="sec-head-left">
        <view class="sec-mark"></view>
        <text class="sec-title">十大香型</text>
        <text class="sec-subtitle">一丛一味</text>
      </view>
      <view class="sec-head-right" bindtap="goToDiscover">
        <text>看全部</text>
        <text class="sec-arrow">›</text>
      </view>
    </view>

    <scroll-view class="aroma-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="aroma-list">
        <view
          class="a-card a-card-{{index}}"
          wx:for="{{aromaTypes}}"
          wx:key="id"
          bindtap="goToDiscover"
          style="--card-bg: {{item._bg || '#e8e0d5'}}; --card-fg: {{item._fg || '#2d2520'}}"
        >
          <view class="a-emoji-wrap">
            <text class="a-emoji">{{item._emoji || '🍃'}}</text>
          </view>
          <text class="a-name">{{item.name}}</text>
          <text class="a-desc">{{item.desc || item.aromaFeature}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ========== 4. 品牌箴言 ========== -->
  <view class="brand-quote" wx:if="{{siteConfig.about}}">
    <view class="bq-wrap">
      <view class="bq-mark bq-mark-l">"</view>
      <text class="bq-text">{{siteConfig.about}}</text>
      <view class="bq-mark bq-mark-r">"</view>
    </view>
  </view>

  <!-- ========== 5. CTA ========== -->
  <view class="cta">
    <view class="cta-btn" bindtap="goToProducts">
      <text class="cta-label">探索更多茶品</text>
      <view class="cta-arrow-wrap">
        <text class="cta-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- ========== 6. 联系我们 ========== -->
  <view class="contact">
    <view class="contact-card" bindtap="showContactModal">
      <view class="contact-icon-wrap">
        <text class="contact-icon">💬</text>
      </view>
      <view class="contact-info">
        <text class="contact-title">联系我们</text>
        <text class="contact-wechat">微信号：{{wechatNumber}}</text>
      </view>
      <view class="contact-action" catchtap="copyWechat">
        <text class="contact-action-text">复制</text>
      </view>
    </view>
  </view>

  <!-- ========== 联系弹窗 ========== -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="hideContactModal">
    <view class="modal-box" catchtap="">
      <view class="modal-header">
        <text class="modal-title">添加微信</text>
        <text class="modal-close" bindtap="hideContactModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="modal-wechat-row">
          <text class="modal-label">微信号</text>
          <text class="modal-wechat">{{wechatNumber}}</text>
        </view>
        <view class="modal-copy-btn" catchtap="copyWechat">
          <text class="modal-copy-text">复制微信号</text>
        </view>
        <!-- 二维码图片 -->
        <view class="modal-qrcode-wrap" wx:if="{{wechatQrcode}}">
          <image class="modal-qrcode" src="{{wechatQrcode}}" mode="widthFix" show-menu-by-longpress="{{true}}" />
        </view>
      </view>
      <view class="modal-footer">
        <text class="modal-hint">长按下方图片扫码添加微信</text>
      </view>
    </view>
  </view>

  <!-- ========== 底部留白 ========== -->
  <view class="footer-space"></view>
</view>
