<view class="page">
  <!-- 品牌大图 Hero -->
  <view class="hero">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <text class="hero-brand">凤凰单枞</text>
      <text class="hero-slogan">一丛一味 · 百丛百香</text>
      <text class="hero-desc">潮州凤凰山 · 高山炭焙 · 传统工艺</text>
    </view>
  </view>

  <!-- 十大香型入口 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">十大香型</text>
      <text class="section-subtitle">凤凰单枞以香型著称，每种香型皆有独特韵味</text>
    </view>
    <scroll-view class="aroma-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
      <view class="aroma-list">
        <view class="aroma-item" wx:for="{{categories}}" wx:key="id" bindtap="goCategory" data-id="{{item.id}}">
          <view class="aroma-icon aroma-{{item.id}}"></view>
          <text class="aroma-name">{{item.name}}</text>
          <text class="aroma-desc">{{item.desc}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 热销推荐 -->
  <view class="section" wx:if="{{hotProducts.length > 0}}">
    <view class="section-header">
      <text class="section-title">茶品推荐</text>
      <view class="section-more" bindtap="goProductList">
        <text>查看全部</text>
        <text class="arrow">→</text>
      </view>
    </view>
    <view class="product-grid">
      <view class="product-card" wx:for="{{hotProducts}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <view class="product-image">
          <image src="{{item.imageUrl || '/images/tea-placeholder.png'}}" mode="aspectFill" lazy-load="true"></image>
          <view class="product-tag" wx:if="{{item.isNew}}">新品</view>
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-brief">{{item.brief}}</text>
          <view class="product-meta">
            <text class="product-price">¥{{item.price}}</text>
            <text class="product-weight">{{item.weight}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 品牌故事 -->
  <view class="story-section">
    <view class="story-content">
      <text class="story-title">关于凤凰单枞</text>
      <text class="story-text">凤凰单枞，产于广东省潮州市凤凰山，是乌龙茶中的极品。因"一丛一味、百丛百香"而得名，每株茶树皆有独特香气。</text>
      <text class="story-text">凤凰山海拔千米以上，云雾缭绕，土壤肥沃，得天独厚的自然环境孕育出品质卓越的单枞茶。</text>
      <text class="story-text">传统炭焙工艺，慢火细烘，保留茶叶本真香气，成就一杯好茶。</text>
    </view>
  </view>

  <!-- 联系我们 -->
  <view class="contact-section">
    <view class="contact-card">
      <text class="contact-title">品茶咨询</text>
      <text class="contact-desc">添加微信，了解更多茶品信息</text>
      <button class="contact-btn" bindtap="copyWechat">
        <text class="btn-icon">📱</text>
        <text>复制微信号</text>
      </button>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="footer-space"></view>
</view>
