<view class="page">

  <!-- ========== 1. Hero 大图区域（全屏500rpx） ========== -->
  <view class="hero">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <text class="hero-brand">{{siteConfig.brandName || '凤凰单枞'}}</text>
      <text class="hero-slogan">{{siteConfig.slogan || '一丛一味 · 百丛百香'}}</text>
      <text class="hero-sub">专注凤凰单枞 · 源自潮州凤凰山</text>
    </view>
  </view>

  <!-- ========== 2. 热销推荐 ========== -->
  <view class="section" wx:if="{{hotProducts.length > 0}}">
    <view class="section-header">
      <text class="section-title">热销推荐</text>
      <view class="section-more" bindtap="goToProducts">
        <text>查看全部</text>
        <text class="arrow-right"> →</text>
      </view>
    </view>
    <view class="product-grid">
      <view
        class="product-card"
        wx:for="{{hotProducts}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="product-image">
          <image src="{{item.imageUrl || item.cover || '/images/banner/banner1.jpg'}}" mode="aspectFill" lazy-load="true"></image>
          <view class="product-tag hot" wx:if="{{item.isHot}}">热销</view>
          <view class="product-tag" wx:elif="{{item.isNew}}">新品</view>
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-aroma-tag" wx:if="{{item.categoryName}}">
            <text>{{item.categoryName}}</text>
          </view>
          <view class="product-meta">
            <text class="product-price">¥{{item.price}}</text>
            <text class="product-spec">{{item.weight}}</text>
          </view>
          <view class="product-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text class="tag-item" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 2}}">{{tag}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 3. 香型快览（横向滚动） ========== -->
  <view class="section" wx:if="{{aromaTypes.length > 0}}">
    <view class="section-header">
      <text class="section-title">十大香型</text>
      <view class="section-more" bindtap="goToDiscover">
        <text>查看全部</text>
        <text class="arrow-right"> →</text>
      </view>
    </view>
    <scroll-view class="aroma-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
      <view class="aroma-list">
        <view
          class="aroma-item"
          wx:for="{{aromaTypes}}"
          wx:key="id"
          bindtap="goToDiscover"
        >
          <view class="aroma-icon-wrap">
            <view class="aroma-icon"></view>
          </view>
          <text class="aroma-name">{{item.name}}</text>
          <text class="aroma-desc">{{item.desc}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ========== 4. 品牌一句话 ========== -->
  <view class="brand-quote" wx:if="{{siteConfig.about}}">
    <view class="brand-quote-inner">
      <view class="brand-quote-line"></view>
      <text class="brand-quote-text">{{siteConfig.about.length > 30 ? siteConfig.about.substring(0, 30) + '...' : siteConfig.about}}</text>
      <view class="brand-quote-line"></view>
    </view>
  </view>

  <!-- ========== 5. 底部 CTA 区域 ========== -->
  <view class="cta-section">
    <view class="cta-btn primary" bindtap="goToProducts">
      <text class="cta-text">探索更多茶品</text>
      <text class="cta-arrow"> →</text>
    </view>
    <view class="cta-btn secondary" bindtap="goToDiscover">
      <text class="cta-text">了解茶文化</text>
      <text class="cta-arrow"> →</text>
    </view>
  </view>

  <!-- ========== 6. 联系客服区域 ========== -->
  <view class="contact-section">
    <view class="contact-btn" wx:if="{{siteConfig.wechat}}" bindtap="copyWechat">
      <view class="contact-icon-wrap">
        <view class="contact-icon"></view>
      </view>
      <text class="contact-text">联系客服 · 复制微信号</text>
    </view>
    <view class="contact-simple" wx:else>
      <text class="contact-text-simple">联系客服</text>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="footer-space"></view>
</view>
