/* 茶知识详情页 - 东方禅意阅读体验 */
.page {
  min-height: 100vh;
  background: #f5f0e8;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #a09080;
  letter-spacing: 2rpx;
}

/* 文章容器 */
.article {
  padding: 0 30rpx;
}

/* 文章头部 */
.article-header {
  padding: 40rpx 0 30rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.article-category {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: rgba(201, 168, 108, 0.12);
  color: #a08050;
  font-size: 20rpx;
  border-radius: 20rpx;
  letter-spacing: 1rpx;
}

.article-date {
  font-size: 20rpx;
  color: #a09080;
  letter-spacing: 1rpx;
}

.article-views {
  font-size: 20rpx;
  color: #b0a090;
  letter-spacing: 1rpx;
}

.article-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #2d2520;
  line-height: 1.5;
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.article-divider {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, #c9a86c, transparent);
}

/* 文章正文 */
.article-body {
  padding: 30rpx 0;
}

.rich-content {
  font-size: 28rpx;
  color: #3d3530;
  line-height: 2;
  letter-spacing: 1rpx;
}

/* rich-text 内部 HTML 样式 */
.rich-content h3 {
  font-size: 34rpx;
  font-weight: 600;
  color: #2d2520;
  margin: 40rpx 0 20rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #c9a86c;
  line-height: 1.5;
}

.rich-content h4 {
  font-size: 30rpx;
  font-weight: 500;
  color: #2d2520;
  margin: 32rpx 0 16rpx;
  line-height: 1.5;
}

.rich-content p {
  margin-bottom: 20rpx;
  text-align: justify;
}

.rich-content b {
  color: #2d2520;
  font-weight: 600;
}

.rich-content br {
  display: block;
  height: 16rpx;
}

/* 文章底部 - 固定操作栏 */
.article-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(45, 37, 32, 0.08);
  z-index: 100;
  padding: 0 40rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.footer-action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 68rpx;
  padding: 0 40rpx;
  background: transparent;
  border-radius: 34rpx;
  border: 1rpx solid rgba(201, 168, 108, 0.2);
}

.footer-action:active {
  background: rgba(201, 168, 108, 0.06);
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 68rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #c9a86c, #b8965c);
  border: none;
  margin: 0;
  line-height: normal;
  font-size: inherit;
  border-radius: 34rpx;
  color: #fff;
}

.share-btn::after {
  border: none;
}

.share-btn .action-icon,
.share-btn .action-text {
  color: #fff;
}

.action-icon {
  font-size: 26rpx;
  color: #c9a86c;
}

.action-text {
  font-size: 24rpx;
  color: #5a5045;
  letter-spacing: 2rpx;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #a09080;
  letter-spacing: 2rpx;
}

/* 底部留白 */
.footer-space {
  height: 140rpx;
}
