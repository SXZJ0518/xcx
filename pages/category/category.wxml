<view class="page">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">十大香型</text>
    <text class="page-subtitle">一丛一味 · 百丛百香</text>
  </view>

  <!-- 香型网格 -->
  <view class="aroma-grid">
    <view class="aroma-card" wx:for="{{categories}}" wx:key="id" bindtap="goProductList" data-id="{{item.id}}">
      <view class="aroma-bg"></view>
      <view class="aroma-content">
        <text class="aroma-name">{{item.name}}</text>
        <text class="aroma-desc">{{item.desc}}</text>
        <view class="aroma-arrow">
          <text>→</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="footer-space"></view>
</view>
