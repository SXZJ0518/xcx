/* 分类页 - 十大香型 */

.page {
  min-height: 100vh;
  background: #f5f0e8;
  padding: 30rpx;
}

.page-header {
  text-align: center;
  padding: 40rpx 0;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 500;
  color: #2d2520;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.page-subtitle {
  display: block;
  font-size: 24rpx;
  color: #8b7355;
  letter-spacing: 4rpx;
}

.aroma-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -15rpx;
}

.aroma-card {
  width: calc(50% - 30rpx);
  margin: 0 15rpx 30rpx;
  height: 200rpx;
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #2d2520, #3d3530);
}

.aroma-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.1;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="none" stroke="%23c9a86c" stroke-width="0.5"/></svg>') center/150rpx repeat;
}

.aroma-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 100%;
  padding: 30rpx;
}

.aroma-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #c9a86c;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.aroma-desc {
  font-size: 22rpx;
  color: #a09080;
  margin-bottom: 20rpx;
}

.aroma-arrow {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
}

.aroma-arrow text {
  font-size: 28rpx;
  color: #c9a86c;
  opacity: 0.6;
}

.footer-space {
  height: 60rpx;
}
