<view class="page">

  <!-- ========== 1. 顶部 Banner ========== -->
  <view class="banner">
    <view class="banner-bg"></view>
    <view class="banner-content">
      <text class="banner-title">一丛一味 百丛百香</text>
      <text class="banner-subtitle">凤凰单枞十大香型</text>
      <view class="banner-divider"></view>
    </view>
  </view>

  <!-- ========== 2. 十大香型 ========== -->
  <view class="section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-title-line"></view>
        <text class="section-title">十大香型</text>
      </view>
      <text class="section-hint" wx:if="{{aromaTypes.length > 0}}">已上架 {{listedCount}}/{{aromaTypes.length}} 种</text>
    </view>

    <view class="aroma-grid">
      <view
        class="aroma-card {{item.yourProduct ? 'has-product featured' : 'coming-soon'}}"
        wx:for="{{aromaTypes}}"
        wx:key="id"
        bindtap="goToProducts"
        data-name="{{item.name}}"
      >
        <view class="aroma-card-bg">
          <view class="aroma-bg-blob" style="transform: translate({{index % 3 * 10}}rpx, -{{index % 2 * 8}}rpx)"></view>
        </view>
        <view class="aroma-card-inner">
          <!-- 序号装饰 -->
          <view class="aroma-index" wx:if="{{item.yourProduct}}">{{index + 1}}</view>

          <view class="aroma-top">
            <text class="aroma-name">{{item.name}}</text>
            <view class="aroma-badge" wx:if="{{item.yourProduct}}">
              <text class="aroma-badge-dot"></text>
              <text>{{item.productCount}}款</text>
            </view>
          </view>
          <text class="aroma-feature">{{item.aromaFeature}}</text>

          <!-- 已上架：显示详细信息 -->
          <view class="aroma-details" wx:if="{{item.yourProduct}}">
            <view class="aroma-detail" wx:if="{{item.representative}}">
              <text class="aroma-detail-label">代表品种</text>
              <text class="aroma-detail-text">{{item.representative}}</text>
            </view>
            <view class="aroma-detail" wx:if="{{item.qualityFeature}}">
              <text class="aroma-detail-label">品质特点</text>
              <text class="aroma-detail-text">{{item.qualityFeature}}</text>
            </view>
          </view>

          <!-- 底部操作 -->
          <view class="aroma-action" wx:if="{{item.yourProduct}}">
            <text class="aroma-arrow">查看商品 →</text>
          </view>
          <view class="aroma-action coming" wx:else>
            <text class="aroma-coming-text">敬请期待</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 3. 茶知识 ========== -->
  <view class="section knowledge-section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-title-line"></view>
        <text class="section-title">茶知识</text>
      </view>
    </view>

    <view class="knowledge-list">
      <view
        class="knowledge-card"
        wx:for="{{knowledgeList}}"
        wx:key="id"
        bindtap="goToKnowledgeDetail"
        data-id="{{item.id}}"
      >
        <view class="knowledge-card-inner">
          <view class="knowledge-top">
            <text class="knowledge-category" wx:if="{{item.category}}">{{item.category}}</text>
            <text class="knowledge-date" wx:if="{{item.createTime}}">{{item.createTime}}</text>
          </view>
          <text class="knowledge-title">{{item.title}}</text>
          <text class="knowledge-summary">{{item.summary}}</text>
          <view class="knowledge-bottom">
            <view class="knowledge-views">
              <view class="views-icon"></view>
              <text class="views-text">{{item.views || 0}}</text>
            </view>
            <text class="knowledge-arrow">阅读全文 →</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 知识空状态 -->
    <view class="empty-knowledge" wx:if="{{!knowledgeList.length}}">
      <text class="empty-text">暂无茶知识文章</text>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="footer-space"></view>
</view>
