/* ============================================================
   发现页样式 - 东方禅意美学
   主色 #c9a86c | 背景 #f5f0e8 | 文字 #2d2520
   ============================================================ */

.page {
  min-height: 100vh;
  background: #f5f0e8;
}

/* ========== 1. 顶部 Banner ========== */
.banner {
  position: relative;
  width: 100%;
  height: 420rpx;
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(160deg, #2d2520 0%, #3d3530 60%, #4a4038 100%);
}

.banner-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 20% 80%, rgba(201, 168, 108, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(201, 168, 108, 0.06) 0%, transparent 50%);
}

.banner-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 60rpx 40rpx;
}

.banner-title {
  font-size: 52rpx;
  font-weight: 300;
  color: #c9a86c;
  letter-spacing: 12rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 6rpx;
  margin-bottom: 28rpx;
}

.banner-divider {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #c9a86c, transparent);
}

/* ========== 2. 十大香型 ========== */
.section {
  padding: 50rpx 30rpx;
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-title-line {
  width: 6rpx;
  height: 32rpx;
  background: #c9a86c;
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #2d2520;
  letter-spacing: 4rpx;
}

/* 香型网格 2列 */
.aroma-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -12rpx;
}

.aroma-card {
  width: calc(50% - 24rpx);
  margin: 0 12rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  transition: transform 0.3s;
}

.aroma-card:active {
  transform: scale(0.97);
}

.aroma-card-inner {
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 37, 32, 0.06);
  border: 1rpx solid rgba(201, 168, 108, 0.1);
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.aroma-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2520;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.aroma-feature {
  display: block;
  font-size: 22rpx;
  color: #8b7355;
  line-height: 1.6;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.aroma-status {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  letter-spacing: 1rpx;
}

.aroma-status.has-product {
  background: rgba(201, 168, 108, 0.12);
  color: #a08050;
  font-weight: 500;
}

.aroma-status.no-product {
  background: #f0ebe0;
  color: #a09080;
}

/* ========== 3. 茶知识 ========== */
.knowledge-section {
  background: linear-gradient(180deg, #f5f0e8 0%, #faf7f0 50%, #f5f0e8 100%);
}

.knowledge-list {
  display: flex;
  flex-direction: column;
}

.knowledge-card {
  margin-bottom: 20rpx;
  transition: transform 0.3s;
}

.knowledge-card:active {
  transform: scale(0.98);
}

.knowledge-card-inner {
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(45, 37, 32, 0.05);
  border: 1rpx solid rgba(201, 168, 108, 0.08);
}

.knowledge-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.knowledge-category {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: rgba(201, 168, 108, 0.1);
  color: #a08050;
  font-size: 20rpx;
  border-radius: 20rpx;
  letter-spacing: 1rpx;
}

.knowledge-date {
  font-size: 20rpx;
  color: #a09080;
  letter-spacing: 1rpx;
}

.knowledge-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #2d2520;
  line-height: 1.5;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.knowledge-summary {
  display: block;
  font-size: 24rpx;
  color: #8b7355;
  line-height: 1.7;
  margin-bottom: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.knowledge-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.knowledge-views {
  display: flex;
  align-items: center;
}

.views-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  position: relative;
}

.views-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 24rpx;
  height: 16rpx;
  border: 2rpx solid #a09080;
  border-radius: 12rpx 12rpx 0 0;
}

.views-icon::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 6rpx solid #a09080;
}

.views-text {
  font-size: 20rpx;
  color: #a09080;
}

.knowledge-arrow {
  font-size: 22rpx;
  color: #c9a86c;
  letter-spacing: 1rpx;
}

/* 知识空状态 */
.empty-knowledge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #a09080;
  letter-spacing: 2rpx;
}

/* ========== 底部留白 ========== */
.footer-space {
  height: 80rpx;
}
