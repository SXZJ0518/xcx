/* important/pages/ar-preview/index.wxss */

.ar-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

/* 加载状态 */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.2);
  border-top: 6rpx solid var(--accent-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

.loading-text {
  color: white;
  font-size: var(--font-size-md);
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 相机授权 */
.auth-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.auth-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 40rpx;
}

.auth-title {
  color: white;
  font-size: var(--font-size-lg);
  font-weight: 600;
  margin-bottom: 20rpx;
}

.auth-desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: var(--font-size-md);
  margin-bottom: 60rpx;
  text-align: center;
  padding: 0 100rpx;
}

.auth-btn {
  background-color: var(--accent-color);
  color: white;
  font-size: var(--font-size-md);
  padding: 20rpx 40rpx;
  border-radius: var(--radius-pill);
  border: none;
}

/* AR视图 */
.ar-view {
  width: 100%;
  height: 100%;
  position: relative;
}

/* 茶具选择器 */
.teaware-selector {
  position: absolute;
  bottom: 30rpx;
  left: 0;
  right: 0;
  height: 180rpx;
  padding: 0 20rpx;
  z-index: 10;
}

.teaware-scroll {
  width: 100%;
  height: 100%;
  white-space: nowrap;
}

.teaware-item {
  display: inline-block;
  width: 140rpx;
  margin-right: 20rpx;
  text-align: center;
  opacity: 0.7;
  transition: all 0.3s ease;
}

.teaware-item.active {
  opacity: 1;
  transform: scale(1.1);
}

.teaware-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  background-color: rgba(0, 0, 0, 0.4);
  margin-bottom: 10rpx;
}

.teaware-item.active .teaware-thumb {
  border-color: var(--accent-color);
  box-shadow: 0 0 10rpx rgba(255, 196, 0, 0.6);
}

.teaware-name {
  color: white;
  font-size: var(--font-size-xs);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 茶具详情 */
.teaware-details {
  position: absolute;
  bottom: -400rpx;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(15px);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 40rpx 30rpx;
  transition: transform 0.3s ease;
  transform: translateY(0);
  z-index: 20;
}

.teaware-details.show {
  transform: translateY(-400rpx);
}

.details-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.details-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.details-close {
  padding: 10rpx;
}

.details-desc {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 30rpx;
  display: block;
}

.details-buttons {
  display: flex;
  justify-content: space-between;
}

.details-btn {
  flex: 1;
  margin: 0 10rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-pill);
  font-size: var(--font-size-md);
}

.details-btn.view {
  background-color: rgba(42, 93, 62, 0.1);
  color: var(--primary-color);
  border: 1rpx solid var(--primary-color);
}

.details-btn.buy {
  background-color: var(--primary-color);
  color: white;
}

/* 使用指引 */
.instructions-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 30;
}

.instructions-content {
  background-color: white;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}

.instructions-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: block;
  text-align: center;
}

.instructions-desc {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  display: block;
  text-align: center;
  line-height: 1.5;
}

.instructions-steps {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30%;
}

.step-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.step-text {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  text-align: center;
}

.instructions-btn {
  background-color: var(--primary-color);
  color: white;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-size-md);
}

/* 帮助按钮 */
.help-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 15;
}

.help-btn image {
  width: 40rpx;
  height: 40rpx;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 15;
}

.back-btn image {
  width: 40rpx;
  height: 40rpx;
} 